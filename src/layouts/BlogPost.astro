---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Widgets from '../components/Widgets.astro';
import ParaFeedback from '../components/ParaFeedback.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead title={`${title} | tnksblog`} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <article>
        {heroImage && (
          <div class="hero-image">
            <img src={heroImage} alt="" />
          </div>
        )}
        <div class="prose">
          <div class="post-header">
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && <span class="updated">（更新: <FormattedDate date={updatedDate} />）</span>}
              <span class="views" id="post-views" hidden>· 👁 <span id="post-views-n">…</span></span>
            </div>
            <h1>{title}</h1>
            <p class="description">{description}</p>
            <hr />
          </div>
          <slot />
          <div class="fav-wrap">
            <button class="fav-btn" id="fav-btn" type="button" aria-pressed="false" title="気に入ったら星を（一人一回）">
              <span class="fav-star">☆</span>
              <span class="fav-label">お気に入り</span>
              <span class="fav-count" id="fav-count">…</span>
            </button>
          </div>
        </div>
      </article>
      <section class="comments" id="comments">
        <h2 class="comments-title">コメント <span class="comments-count" id="comments-count"></span></h2>
        <div class="comments-list" id="comments-list">
          <p class="comments-empty" id="comments-empty">まだコメントはないよ。最初のひとことをどうぞ。</p>
        </div>
        <form class="comment-form" id="comment-form">
          <input type="text" id="comment-name" maxlength="40" placeholder="名前（任意）" autocomplete="off" />
          <textarea id="comment-text" maxlength="1000" rows="3" placeholder="コメントを書く…（最大1000文字）" required></textarea>
          <label class="comment-ask">
            <input type="checkbox" id="comment-ask" />
            <span>ランキンに質問する（あとで著者から返信がつくよ）</span>
          </label>
          <div class="comment-form-foot">
            <span class="comment-msg" id="comment-msg"></span>
            <button type="submit" class="comment-submit" id="comment-submit">送信</button>
          </div>
        </form>
      </section>
    </main>
    <Footer />
    <Widgets />
    <ParaFeedback />
    <script>
      // 閲覧数: セッションごとに1回だけ加算して表示する
      (() => {
        const API = 'https://feedback.tnks1407.com';
        const slug = location.pathname.replace(/\/+$/, '').split('/').pop() || '';
        if (!/^[a-z0-9][a-z0-9-]{0,80}$/.test(slug)) return;
        const show = (n: number | undefined) => {
          const el = document.getElementById('post-views');
          const nn = document.getElementById('post-views-n');
          if (el && nn && typeof n === 'number') { nn.textContent = n.toLocaleString(); el.hidden = false; }
        };
        const key = '_viewed_' + slug;
        if (!sessionStorage.getItem(key)) {
          sessionStorage.setItem(key, '1');
          fetch(API + '/view?key=' + encodeURIComponent(slug), { method: 'POST' })
            .then(r => r.json()).then(d => show(d.count)).catch(() => {});
        } else {
          fetch(API + '/views').then(r => r.json()).then(d => show(d[slug])).catch(() => {});
        }
      })();

      // お気に入り（★）: 一人一回。localStorage(端末)＋サーバIP重複チェックの二段
      (() => {
        const API = 'https://feedback.tnks1407.com';
        const slug = location.pathname.replace(/\/+$/, '').split('/').pop() || '';
        if (!/^[a-z0-9][a-z0-9-]{0,80}$/.test(slug)) return;
        const btn = document.getElementById('fav-btn');
        const countEl = document.getElementById('fav-count');
        if (!btn || !countEl) return;
        const starEl = btn.querySelector('.fav-star') as HTMLElement;
        const favedKey = '_faved_' + slug;
        let faved = !!localStorage.getItem(favedKey);
        const render = (count?: number) => {
          if (typeof count === 'number') countEl.textContent = count.toLocaleString();
          if (faved) {
            btn.classList.add('faved');
            btn.setAttribute('aria-pressed', 'true');
            if (starEl) starEl.textContent = '★';
          }
        };
        render();
        fetch(API + '/favs').then(r => r.json()).then(d => render(d[slug] || 0)).catch(() => { countEl.textContent = '0'; });
        btn.addEventListener('click', () => {
          if (faved) return;
          faved = true; localStorage.setItem(favedKey, '1'); render();
          fetch(API + '/fav?key=' + encodeURIComponent(slug), { method: 'POST' })
            .then(r => r.json()).then(d => render(d.count)).catch(() => {});
        });
      })();

      // コメント欄: slug単位。表示は textContent で組み立て（XSS対策）
      (() => {
        const API = 'https://feedback.tnks1407.com';
        const slug = location.pathname.replace(/\/+$/, '').split('/').pop() || '';
        if (!/^[a-z0-9][a-z0-9-]{0,80}$/.test(slug)) return;
        const listEl = document.getElementById('comments-list');
        const emptyEl = document.getElementById('comments-empty');
        const countEl = document.getElementById('comments-count');
        const form = document.getElementById('comment-form') as HTMLFormElement | null;
        const nameEl = document.getElementById('comment-name') as HTMLInputElement | null;
        const textEl = document.getElementById('comment-text') as HTMLTextAreaElement | null;
        const msgEl = document.getElementById('comment-msg');
        const btn = document.getElementById('comment-submit') as HTMLButtonElement | null;
        const askEl = document.getElementById('comment-ask') as HTMLInputElement | null;
        if (!listEl || !form || !nameEl || !textEl || !btn) return;

        const fmtDate = (ts: string) => {
          try { return new Date(ts).toLocaleString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }); }
          catch { return ''; }
        };
        const renderOne = (c: { name?: string; text: string; ts: string; q?: boolean; reply?: string | null; reply_ts?: string | null }) => {
          const item = document.createElement('div'); item.className = 'comment-item' + (c.q ? ' is-q' : '');
          const head = document.createElement('div'); head.className = 'comment-head';
          const nm = document.createElement('span'); nm.className = 'comment-name'; nm.textContent = c.name || '名無し';
          if (c.q) { const b = document.createElement('span'); b.className = 'comment-qbadge'; b.textContent = '質問'; nm.appendChild(document.createTextNode(' ')); nm.appendChild(b); }
          const dt = document.createElement('span'); dt.className = 'comment-date'; dt.textContent = fmtDate(c.ts);
          head.appendChild(nm); head.appendChild(dt);
          const body = document.createElement('div'); body.className = 'comment-text'; body.textContent = c.text;
          item.appendChild(head); item.appendChild(body);
          if (c.reply) {
            const rep = document.createElement('div'); rep.className = 'comment-reply';
            const rh = document.createElement('div'); rh.className = 'comment-reply-head';
            const rl = document.createElement('span'); rl.className = 'comment-reply-name'; rl.textContent = '★ ランキン';
            rh.appendChild(rl);
            if (c.reply_ts) { const rd = document.createElement('span'); rd.className = 'comment-date'; rd.textContent = fmtDate(c.reply_ts); rh.appendChild(rd); }
            const rb = document.createElement('div'); rb.className = 'comment-text'; rb.textContent = c.reply;
            rep.appendChild(rh); rep.appendChild(rb);
            item.appendChild(rep);
          } else if (c.q) {
            const pend = document.createElement('div'); pend.className = 'comment-reply-pending'; pend.textContent = 'ランキンの返信を待っています…';
            item.appendChild(pend);
          }
          return item;
        };
        const setCount = (n: number) => { if (countEl) countEl.textContent = n ? '(' + n + ')' : ''; };

        fetch(API + '/comments?key=' + encodeURIComponent(slug)).then(r => r.json()).then((list) => {
          if (!Array.isArray(list)) return;
          if (list.length === 0) { if (emptyEl) (emptyEl as HTMLElement).hidden = false; }
          else {
            if (emptyEl) (emptyEl as HTMLElement).hidden = true;
            list.forEach((c) => listEl.appendChild(renderOne(c)));
          }
          setCount(list.length);
        }).catch(() => {});

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const text = (textEl.value || '').trim();
          if (!text) return;
          const asked = !!(askEl && askEl.checked);
          btn.disabled = true; if (msgEl) msgEl.textContent = '送信中…';
          fetch(API + '/comment?key=' + encodeURIComponent(slug), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: nameEl.value || '', text, question: asked }),
          }).then(r => r.json().then((d) => ({ ok: r.ok, d })))
            .then(({ ok, d }) => {
              if (ok && d.comment) {
                if (emptyEl) (emptyEl as HTMLElement).hidden = true;
                listEl.appendChild(renderOne({ ...d.comment, q: asked }));
                setCount(listEl.querySelectorAll('.comment-item').length);
                textEl.value = ''; if (askEl) askEl.checked = false;
                if (msgEl) msgEl.textContent = asked ? 'ありがとう、質問を受け取ったよ。あとで返信がつくよ。' : 'ありがとう、投稿したよ。';
              } else if (msgEl) {
                msgEl.textContent = (d && d.error) ? d.error : '送信できなかった…';
              }
            }).catch(() => { if (msgEl) msgEl.textContent = '送信できなかった…'; })
            .finally(() => { btn.disabled = false; setTimeout(() => { if (msgEl) msgEl.textContent = ''; }, 4000); });
        });
      })();
    </script>
  </body>
</html>

<style>
  main { max-width: 740px; margin: 0 auto; padding: 2rem 1rem; }
  .hero-image img { width: 100%; border-radius: 12px; margin-bottom: 2rem; }
  .post-header { margin-bottom: 2rem; }
  .date { color: var(--text-faint); font-size: 0.8rem; margin-bottom: 0.75rem; font-family: 'JetBrains Mono', monospace; }
  .updated { margin-left: 0.5rem; }
  h1 { font-size: 1.9rem; line-height: 1.25; margin-bottom: 0.75rem; font-weight: 700; }
  .description { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  hr { border-color: var(--border); margin-bottom: 2rem; }
  .prose { line-height: 1.9; }
  .prose h2 {
    margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.45rem;
    color: var(--accent); font-weight: 700;
  }
  .prose h2::before { content: '# '; opacity: 0.35; font-family: 'JetBrains Mono', monospace; font-size: 0.85em; }
  .prose h3 { margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.15rem; color: var(--text); }
  .fav-wrap { margin: 3rem 0 0.5rem; display: flex; justify-content: center; }
  .fav-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; color: var(--text-muted);
    background: var(--card); border: 1px solid var(--border); border-radius: 999px;
    padding: 0.5rem 1.15rem; cursor: pointer; transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .fav-btn:hover { border-color: var(--accent); color: var(--accent); }
  .fav-btn .fav-star { font-size: 1.15rem; line-height: 1; }
  .fav-btn.faved { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); cursor: default; }
  .fav-btn.faved .fav-star { color: #e8b339; }
  .fav-count { font-weight: 600; min-width: 1ch; }

  .comments { max-width: 740px; margin: 3.5rem auto 0; padding-top: 2rem; border-top: 1px solid var(--border); }
  .comments-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 1.25rem; }
  .comments-count { color: var(--text-faint); font-size: 0.9rem; font-weight: 500; font-family: 'JetBrains Mono', monospace; }
  .comments-list { display: flex; flex-direction: column; gap: 0.85rem; margin-bottom: 1.75rem; }
  .comments-empty { color: var(--text-faint); font-size: 0.9rem; }
  .comment-item { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 0.85rem 1rem; }
  .comment-head { display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; margin-bottom: 0.4rem; }
  .comment-name { font-weight: 700; font-size: 0.9rem; color: var(--text); }
  .comment-date { color: var(--text-faint); font-size: 0.72rem; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .comment-text { font-size: 0.92rem; line-height: 1.75; white-space: pre-wrap; word-break: break-word; }
  .comment-form { display: flex; flex-direction: column; gap: 0.6rem; }
  .comment-form input, .comment-form textarea { width: 100%; font-family: inherit; font-size: 0.92rem; color: var(--text); background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 0.6rem 0.8rem; }
  .comment-form input:focus, .comment-form textarea:focus { outline: none; border-color: var(--accent); }
  .comment-form textarea { resize: vertical; min-height: 3.5rem; line-height: 1.7; }
  .comment-form-foot { display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; }
  .comment-msg { font-size: 0.8rem; color: var(--text-muted); }
  .comment-submit { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 600; color: #fff; background: var(--accent); border: 1px solid var(--accent); border-radius: 999px; padding: 0.45rem 1.3rem; cursor: pointer; transition: opacity 0.15s; }
  .comment-submit:hover { opacity: 0.85; }
  .comment-submit:disabled { opacity: 0.5; cursor: default; }
  .comment-ask { display: flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; color: var(--text-muted); cursor: pointer; user-select: none; }
  .comment-ask input { accent-color: var(--accent); width: auto; }
  .comment-item.is-q { border-color: rgba(60,120,118,0.4); }
  .comment-qbadge { font-size: 0.66rem; font-weight: 700; color: var(--accent); background: var(--accent-dim); border: 1px solid rgba(60,120,118,0.3); border-radius: 999px; padding: 0.05rem 0.5rem; margin-left: 0.1rem; font-family: 'JetBrains Mono', monospace; vertical-align: 1px; }
  .comment-reply { margin-top: 0.7rem; padding: 0.7rem 0.85rem; background: var(--accent-dim); border-left: 3px solid var(--accent); border-radius: 0 10px 10px 0; }
  .comment-reply-head { display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; margin-bottom: 0.3rem; }
  .comment-reply-name { font-weight: 700; font-size: 0.85rem; color: var(--accent); }
  .comment-reply .comment-text { font-size: 0.9rem; }
  .comment-reply-pending { margin-top: 0.6rem; font-size: 0.78rem; color: var(--text-faint); font-style: italic; }
</style>
