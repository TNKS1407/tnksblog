---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Widgets from '../components/Widgets.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead title={`${title} | tnksblog`} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <article>
        {heroImage && (
          <div class="hero-image">
            <img src={heroImage} alt="" />
          </div>
        )}
        <div class="prose">
          <div class="post-header">
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && <span class="updated">（更新: <FormattedDate date={updatedDate} />）</span>}
              <span class="views" id="post-views" hidden>· 👁 <span id="post-views-n">…</span></span>
            </div>
            <h1>{title}</h1>
            <p class="description">{description}</p>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <Widgets />
    <script>
      // 閲覧数: セッションごとに1回だけ加算して表示する
      (() => {
        const API = 'https://feedback.tnks1407.com';
        const slug = location.pathname.replace(/\/+$/, '').split('/').pop() || '';
        if (!/^[a-z0-9][a-z0-9-]{0,80}$/.test(slug)) return;
        const show = (n: number | undefined) => {
          const el = document.getElementById('post-views');
          const nn = document.getElementById('post-views-n');
          if (el && nn && typeof n === 'number') { nn.textContent = n.toLocaleString(); el.hidden = false; }
        };
        const key = '_viewed_' + slug;
        if (!sessionStorage.getItem(key)) {
          sessionStorage.setItem(key, '1');
          fetch(API + '/view?key=' + encodeURIComponent(slug), { method: 'POST' })
            .then(r => r.json()).then(d => show(d.count)).catch(() => {});
        } else {
          fetch(API + '/views').then(r => r.json()).then(d => show(d[slug])).catch(() => {});
        }
      })();
    </script>
  </body>
</html>

<style>
  main { max-width: 740px; margin: 0 auto; padding: 2rem 1rem; }
  .hero-image img { width: 100%; border-radius: 12px; margin-bottom: 2rem; }
  .post-header { margin-bottom: 2rem; }
  .date { color: var(--text-faint); font-size: 0.8rem; margin-bottom: 0.75rem; font-family: 'JetBrains Mono', monospace; }
  .updated { margin-left: 0.5rem; }
  h1 { font-size: 1.9rem; line-height: 1.25; margin-bottom: 0.75rem; font-weight: 700; }
  .description { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }
  hr { border-color: var(--border); margin-bottom: 2rem; }
  .prose { line-height: 1.9; }
  .prose h2 {
    margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.45rem;
    color: var(--accent); font-weight: 700;
  }
  .prose h2::before { content: '# '; opacity: 0.35; font-family: 'JetBrains Mono', monospace; font-size: 0.85em; }
  .prose h3 { margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.15rem; color: var(--text); }
</style>
