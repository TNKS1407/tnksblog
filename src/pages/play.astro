---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="ja">
<head>
  <BaseHead title="Play — tnkblog" description="ランキンの遊び場。フーリエ スケッチブックほか。" />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
  <style>
    .play-intro{
      background:var(--card,#fff);border:1px solid var(--border,#e3dbd0);
      border-radius:14px;padding:1.5rem 1.75rem;margin-bottom:2.5rem;
      box-shadow:0 1px 6px rgba(29,27,23,.05);
    }
    .play-intro p{font-size:.9rem;color:var(--text-muted,#7d7568);line-height:1.75;margin-bottom:.5rem;}
    .play-intro p:last-child{margin-bottom:0;}

    .app-card{
      background:var(--card,#fff);border:1px solid var(--border,#e3dbd0);
      border-radius:14px;padding:1.5rem;margin-bottom:2rem;
      box-shadow:0 1px 6px rgba(29,27,23,.05);
    }
    .app-title{font-size:1.05rem;font-weight:700;margin-bottom:.3rem;}
    .app-desc{font-size:.8rem;color:var(--text-muted,#7d7568);margin-bottom:1.25rem;line-height:1.6;}

    /* Fourier Sketchbook */
    .fourier-wrap{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    @media(max-width:640px){.fourier-wrap{grid-template-columns:1fr;}}
    canvas{border:1px solid var(--border,#e3dbd0);border-radius:10px;display:block;
      background:#faf8f4;cursor:crosshair;touch-action:none;}
    .canvas-label{font-size:.7rem;font-family:'JetBrains Mono',monospace;
      color:var(--text-muted,#7d7568);margin-bottom:.4rem;letter-spacing:.04em;}

    .controls{display:flex;flex-wrap:wrap;gap:.75rem;align-items:center;margin-top:1rem;}
    .ctrl-group{display:flex;align-items:center;gap:.5rem;}
    .ctrl-group label{font-size:.72rem;font-family:'JetBrains Mono',monospace;
      color:var(--text-muted,#7d7568);white-space:nowrap;}
    .ctrl-group input[type=range]{width:100px;accent-color:#3c7876;}
    .ctrl-group span{font-size:.72rem;font-family:'JetBrains Mono',monospace;
      color:#3c7876;font-weight:700;min-width:2ch;}
    .btn{padding:.35rem .85rem;border:1px solid var(--border,#e3dbd0);border-radius:7px;
      background:none;font-family:inherit;font-size:.78rem;color:var(--text-muted,#7d7568);
      cursor:pointer;transition:all .15s;}
    .btn:hover{border-color:#3c7876;color:#3c7876;}
    .btn.primary{background:#3c7876;color:#fff;border-color:#3c7876;}
    .btn.primary:hover{opacity:.85;}

    .status{font-size:.72rem;font-family:'JetBrains Mono',monospace;
      color:var(--text-faint,#aaa49b);margin-top:.5rem;}

    /* Preset buttons */
    .presets{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.5rem;}
    .preset-btn{padding:.22rem .6rem;border:1px solid var(--border,#e3dbd0);border-radius:5px;
      font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--text-muted,#7d7568);
      background:none;cursor:pointer;transition:all .15s;}
    .preset-btn:hover{border-color:#3c7876;color:#3c7876;}

    .gs-math{margin-top:1.25rem;border-top:1px solid var(--border,#e3dbd0);padding-top:1rem;}
    .gs-math-title{font-size:.72rem;font-weight:800;color:#3c7876;letter-spacing:.05em;font-family:'JetBrains Mono',monospace;margin-bottom:.9rem;}
    .gs-math-row{margin:0 0 1.1rem;}
    .gs-math-lab{display:block;font-size:.8rem;font-weight:700;color:#3c7876;margin-bottom:.4rem;}
    .gs-math-row [data-tex]{display:block;overflow-x:auto;overflow-y:hidden;background:var(--surface,#faf8f4);border:1px solid var(--border,#e3dbd0);border-radius:10px;padding:.35rem .8rem;}
    .gs-math-row .katex-display{margin:.35rem 0;}
    .gs-math .katex{font-size:1.05em;}
    .gs-math-cap{display:block;font-size:.72rem;color:var(--text-muted,#7d7568);margin-top:.4rem;line-height:1.6;}
  </style>
</head>
<body>
  <Header />
  <main>

    <div class="play-intro">
      <p>ここはランキンの遊び場。ブログより気楽なやつ。</p>
      <p>好奇心のまま作ったものを置いている。使い方があってもなくても、まあいい。</p>
    </div>

    <a href="/conv" class="app-card" style="display:block;text-decoration:none;color:inherit;border-color:#3c7876;">
      <div class="app-title">畳み込みを一歩ずつ →</div>
      <div class="app-desc">12×12 の小さな画像で、ぼかし・Sobel・Prewitt の計算が一マスずつ進む様子を見る専用ページ。カーネルが格子を舐めて、9個の掛け算→合計→出力が埋まる。</div>
    </a>

    <a href="/dots" class="app-card" style="display:block;text-decoration:none;color:inherit;border-color:#3c7876;">
      <div class="app-title">写真をドット絵に →</div>
      <div class="app-desc">本物の写真を取り込んで、各ブロックの平均RGBを一歩ずつ計算してドット絵にする。"ちゃんとした縮小＝面積平均"が目に見える（最近傍との比較つき）。</div>
    </a>

    <!-- Compactness / open cover -->
    <div class="app-card">
      <div class="app-title">コンパクト性 — 開区間はなぜ"覆いきれない"のか</div>
      <div class="app-desc">
        区間を「開いた毛布（開区間）」で覆っていく。コンパクトとは「どんな覆い方をしても、有限枚だけ選んで覆い直せる」こと。<br>
        閉区間 [0,1] はいつでも有限枚で足りる。でも開区間 (0,1) は、端の 0 に向かって毛布を無限に小さくし続けないと覆えない——その「追いつかない」感じを動かして確かめる。覆いの族は Uₙ =（1/(n+1), 1）。
      </div>
      <div class="canvas-label">NUMBER LINE — 毛布(開区間)で覆う ／ 赤 = まだ覆えていない</div>
      <canvas id="cmp-cv" width="720" height="300" style="width:100%;height:auto;cursor:default;"></canvas>
      <div class="controls">
        <div class="ctrl-group">
          <button class="btn primary" id="cmp-open" type="button">開区間 (0,1)</button>
          <button class="btn" id="cmp-closed" type="button">閉区間 [0,1]</button>
        </div>
        <div class="ctrl-group">
          <label>毛布の枚数 N</label>
          <input type="range" id="cmp-n" min="1" max="40" value="4">
          <span id="cmp-n-v">4</span>
        </div>
        <button class="btn" id="cmp-more" type="button">もっと増やす ▶</button>
      </div>
      <div class="status" id="cmp-status"></div>
    </div>

    <script is:inline>
    (function(){
      var cv = document.getElementById('cmp-cv');
      if(!cv) return;
      var ctx = cv.getContext('2d');
      var W = cv.width, H = cv.height;
      var mode = 'open';   // 'open' | 'closed'
      var N = 4;
      var timer = null;

      var DMIN = -0.20, DMAX = 1.08, PADL = 40, PADR = 28;
      function px(x){ return PADL + (x - DMIN) / (DMAX - DMIN) * (W - PADL - PADR); }
      var AX = H - 64;                  // 数直線の y
      var ANCHOR = { a: -0.05, b: 0.22 }; // 閉区間モードで 0 をまたぐ毛布
      var TEAL = '#3c7876', RED = '#c2543d', GREEN = '#2f9e6e';

      function bl(n){ return 1 / (n + 1); }   // Uₙ = (1/(n+1), 1) の左端

      function rrect(x, y, w, h, r){
        if(w < 2*r) r = w/2; if(h < 2*r) r = h/2;
        ctx.beginPath();
        ctx.moveTo(x+r,y); ctx.arcTo(x+w,y,x+w,y+h,r); ctx.arcTo(x+w,y+h,x,y+h,r);
        ctx.arcTo(x,y+h,x,y,r); ctx.arcTo(x,y,x+w,y,r); ctx.closePath();
      }

      function track(x0, x1, color, lw){
        ctx.strokeStyle = color; ctx.lineWidth = lw; ctx.lineCap = 'round';
        ctx.beginPath(); ctx.moveTo(px(x0), AX); ctx.lineTo(px(x1), AX); ctx.stroke();
      }

      function draw(){
        ctx.clearRect(0,0,W,H);
        var L = bl(N);
        var covered = (mode === 'closed') && (L <= ANCHOR.b);
        var ns = Math.floor(1/ANCHOR.b - 1) + 1;  // 橋渡しに要る最小の n（緑とつながる毛布）

        // 毛布(開区間)の積み重ね
        var top = 18, bottomLevel = AX - 16;
        var step = Math.min(14, (bottomLevel - top) / N);
        var bh = Math.max(2.5, step * 0.62);
        for(var n = 1; n <= N; n++){
          var y = bottomLevel - (n-1) * step - bh;
          var xL = px(bl(n)), xR = px(1);
          var t = (n-1) / Math.max(1, N-1);
          var bridge = covered && (n === ns);
          ctx.globalAlpha = bridge ? 1 : (covered ? 0.13 : (0.30 + 0.45 * (1-t)));
          ctx.fillStyle = TEAL;
          rrect(xL, y, xR - xL, bh, bh/2); ctx.fill();
          if(bridge){
            ctx.globalAlpha = 1; ctx.strokeStyle = '#1d1b17'; ctx.lineWidth = 1.5;
            rrect(xL, y, xR - xL, bh, bh/2); ctx.stroke();
            ctx.fillStyle = '#1d1b17'; ctx.font = '11px monospace'; ctx.textAlign = 'left';
            ctx.fillText('この1枚 (U' + ns + ')', xL, y - 4);
          }
        }
        ctx.globalAlpha = 1;

        // 閉区間モード: 0 をまたぐ緑の毛布
        if(mode === 'closed'){
          var ay = bottomLevel + 2;
          ctx.globalAlpha = 1; ctx.fillStyle = GREEN;
          rrect(px(ANCHOR.a), ay, px(ANCHOR.b) - px(ANCHOR.a), 7, 3); ctx.fill();
          if(covered){ ctx.strokeStyle = '#1d1b17'; ctx.lineWidth = 1.5;
            rrect(px(ANCHOR.a), ay, px(ANCHOR.b) - px(ANCHOR.a), 7, 3); ctx.stroke(); }
          ctx.fillStyle = GREEN; ctx.font = '11px monospace'; ctx.textAlign = 'left';
          ctx.fillText('0をまたぐ1枚', px(ANCHOR.a), ay + 22);
        }

        // 数直線ベース(灰) → 覆えた所(teal) → 覆えてない所(赤)
        track(0, 1, '#d9d2c6', 6);
        var sliver;
        if(mode === 'open'){
          track(L, 1, TEAL, 6);
          sliver = { from: 0, to: L, empty: (L <= 0) };
        } else {
          // 覆い = (ANCHOR.a, ANCHOR.b) ∪ (L, 1)
          track(0, Math.min(ANCHOR.b, 1), TEAL, 6);
          if(L < 1) track(L, 1, TEAL, 6);
          if(L <= ANCHOR.b) sliver = { from: 0, to: 0, empty: true };
          else sliver = { from: ANCHOR.b, to: L, empty: false };
        }
        if(!sliver.empty && sliver.to > sliver.from) track(sliver.from, sliver.to, RED, 6);

        // 端点マーカー(0 と 1)
        function endpoint(x){
          ctx.lineWidth = 2; ctx.strokeStyle = '#1d1b17'; ctx.fillStyle = '#faf8f4';
          ctx.beginPath(); ctx.arc(px(x), AX, 5, 0, Math.PI*2);
          if(mode === 'closed'){ ctx.fillStyle = '#1d1b17'; ctx.fill(); }
          else { ctx.fill(); ctx.stroke(); }
        }
        endpoint(0); endpoint(1);

        // 目盛りラベル
        ctx.fillStyle = '#7d7568'; ctx.font = '12px monospace'; ctx.textAlign = 'center';
        ctx.fillText('0', px(0), AX + 22);
        ctx.fillText('1', px(1), AX + 22);
        // 1/(N+1) マーカー
        if(L > 0.02 && L < 0.98){
          ctx.strokeStyle = RED; ctx.lineWidth = 1; ctx.setLineDash([3,3]);
          ctx.beginPath(); ctx.moveTo(px(L), AX-10); ctx.lineTo(px(L), AX+10); ctx.stroke();
          ctx.setLineDash([]);
          ctx.fillStyle = RED; ctx.fillText('1/(N+1)', px(L), AX + 36);
        }

        // 赤い隙間に矢印＋注記
        if(!sliver.empty && sliver.to - sliver.from > 0.001){
          var mid = (sliver.from + sliver.to) / 2;
          ctx.fillStyle = RED; ctx.font = '12px monospace'; ctx.textAlign = 'center';
          ctx.fillText('まだ覆えてない', px(mid), AX - 26);
          ctx.beginPath(); ctx.moveTo(px(mid), AX - 22); ctx.lineTo(px(mid), AX - 6); ctx.stroke();
        }
      }

      function status(){
        var el = document.getElementById('cmp-status');
        var L = bl(N);
        var Ls = L.toFixed(4);
        var ns = Math.floor(1/ANCHOR.b - 1) + 1;
        if(mode === 'open'){
          el.textContent = '覆えた範囲 (1/(N+1), 1) = (' + Ls + ', 1)。まだ覆えてない (0, ' + Ls + ']。'
            + '毛布は開区間だから端点 1/(N+1) 自身も覆われず残る（だから "]"）。'
            + 'N を増やすと赤い隙間は縮むけど 0 には永遠に届かない —— だから (0,1) はコンパクトでない。';
          el.style.color = RED;
        } else {
          if(L <= ANCHOR.b){
            el.textContent = '覆えた！ 実は「0をまたぐ緑の1枚」＋「U' + ns + ' の1枚」の たった2枚で [0,1] 全部に届く（他は要らない＝薄く表示）。'
              + '0 が"在る"から、0 をまたぐ毛布が必ず右に幅をもって橋渡しになり、無限の追いかけっこが終わる。これがコンパクト（ハイネ・ボレル）。';
            el.style.color = GREEN;
          } else {
            el.textContent = '0 をまたぐ緑の毛布を置いた（右に幅 ' + ANCHOR.b.toFixed(2) + ' まで）。でもまだ [' + ANCHOR.b.toFixed(2) + ', ' + Ls + '] に隙間。'
              + 'N を増やして、緑とつながる毛布（U' + ns + '）まで出すと覆いきれる。';
            el.style.color = '#7d7568';
          }
        }
      }

      function render(){ draw(); status(); }

      function setMode(m){
        mode = m;
        document.getElementById('cmp-open').classList.toggle('primary', m==='open');
        document.getElementById('cmp-closed').classList.toggle('primary', m==='closed');
        render();
      }
      function setN(v){
        N = v;
        document.getElementById('cmp-n').value = v;
        document.getElementById('cmp-n-v').textContent = v;
        render();
      }

      document.getElementById('cmp-open').addEventListener('click', function(){ setMode('open'); });
      document.getElementById('cmp-closed').addEventListener('click', function(){ setMode('closed'); });
      document.getElementById('cmp-n').addEventListener('input', function(e){
        if(timer){ clearInterval(timer); timer = null; }
        setN(parseInt(e.target.value, 10));
      });
      document.getElementById('cmp-more').addEventListener('click', function(){
        if(timer){ clearInterval(timer); timer = null; return; }
        timer = setInterval(function(){
          if(N >= 40){ clearInterval(timer); timer = null; return; }
          setN(N + 1);
        }, 220);
      });

      render();
    })();
    </script>

    <!-- Movable pulley: force / distance / work -->
    <div class="app-card">
      <div class="app-title">動滑車 — 「力が半分」はどこで崩れる？</div>
      <div class="app-desc">
        動滑車は「力が半分・距離が2倍」。でもそれはロープが平行（θ=0）のときだけ。ロープが角度 θ で開くと、上向きに効くのは 2T·cosθ ぶん。<br>
        だから必要な力は W/(2cosθ) に増える。なのに「した仕事」は W×(持ち上げ高さ) のまま変わらない —— 力と距離は崩れても、仕事＝位置エネルギーの増加は崩れない。θ を動かして確かめて。
      </div>
      <div class="canvas-label">θ を動かす ／ 緑 = あなたが引く張力 T, 赤 = 重さ W</div>
      <canvas id="pul-cv" width="720" height="360" style="width:100%;height:auto;cursor:default;"></canvas>
      <div class="controls">
        <div class="ctrl-group">
          <label>ロープの角度 θ</label>
          <input type="range" id="pul-th" min="0" max="75" value="0">
          <span id="pul-th-v">0°</span>
        </div>
      </div>
      <div class="status" id="pul-status"></div>
    </div>

    <script is:inline>
    (function(){
      var cv = document.getElementById('pul-cv');
      if(!cv) return;
      var ctx = cv.getContext('2d');
      var W = cv.width, H = cv.height;
      var th = 0;                       // 角度(度)
      var TEAL = '#3c7876', RED = '#c2543d', GREEN = '#2f9e6e', INK = '#1d1b17';

      function arrow(x0, y0, x1, y1, col, lw){
        ctx.strokeStyle = col; ctx.fillStyle = col; ctx.lineWidth = lw;
        ctx.beginPath(); ctx.moveTo(x0,y0); ctx.lineTo(x1,y1); ctx.stroke();
        var a = Math.atan2(y1-y0, x1-x0), h = 7;
        ctx.beginPath(); ctx.moveTo(x1,y1);
        ctx.lineTo(x1 - h*Math.cos(a - 0.4), y1 - h*Math.sin(a - 0.4));
        ctx.lineTo(x1 - h*Math.cos(a + 0.4), y1 - h*Math.sin(a + 0.4));
        ctx.closePath(); ctx.fill();
      }

      function draw(){
        ctx.clearRect(0,0,W,H);
        var rad = th * Math.PI/180, c = Math.cos(rad), s = Math.sin(rad);
        // 比率
        var forceR = 1/(2*c);    // T/W
        var distR  = 2*c;        // 引くロープ / 持ち上げ
        var workR  = forceR * distR; // = 1

        // --- 図(左) ---
        var ceil = 44, cx = 190, py = 150, r = 20;
        var dx = r + (py - ceil) * Math.tan(rad);
        var aL = cx - dx, aR = cx + dx;
        // 天井
        ctx.strokeStyle = INK; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.moveTo(40, ceil); ctx.lineTo(360, ceil); ctx.stroke();
        for(var hx = 46; hx < 360; hx += 14){ ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(hx, ceil); ctx.lineTo(hx-7, ceil-8); ctx.stroke(); }
        // ロープ(緑)
        ctx.strokeStyle = GREEN; ctx.lineWidth = 2.5;
        ctx.beginPath(); ctx.moveTo(aL, ceil); ctx.lineTo(cx - r, py); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(aR, ceil); ctx.lineTo(cx + r, py); ctx.stroke();
        // 動滑車
        ctx.fillStyle = '#fff'; ctx.strokeStyle = INK; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(cx, py, r, 0, Math.PI*2); ctx.fill(); ctx.stroke();
        ctx.beginPath(); ctx.arc(cx, py, 4, 0, Math.PI*2); ctx.fillStyle = INK; ctx.fill();
        // 荷重
        ctx.strokeStyle = INK; ctx.lineWidth = 2; ctx.beginPath();
        ctx.moveTo(cx, py + r); ctx.lineTo(cx, py + r + 12); ctx.stroke();
        ctx.fillStyle = '#f0ece6'; ctx.strokeStyle = INK;
        ctx.fillRect(cx-18, py+r+12, 36, 24); ctx.strokeRect(cx-18, py+r+12, 36, 24);

        // --- 力ベクトルの分解（右ロープ側で図示） ---
        var ux = Math.sin(rad), uy = -Math.cos(rad);   // 右ロープ方向の単位ベクトル(上向き)
        var Tlen = 70 * forceR;                         // T の長さ(力に比例)
        var ex = cx + r, ey = py;                       // 右ロープの付け根
        var tx = ex + ux * Tlen, ty = ey + uy * Tlen;   // T 先端
        // T（ロープ方向・緑）
        arrow(ex, ey, tx, ty, GREEN, 2.5);
        // 分解の補助線（T cosθ = 縦, T sinθ = 横）
        ctx.strokeStyle = '#b9b1a4'; ctx.setLineDash([3,3]); ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(tx, ty); ctx.lineTo(ex, ty); ctx.stroke();   // 横→縦の補助
        ctx.setLineDash([]);
        // 縦成分 T cosθ（青緑、太め）
        arrow(ex, ey, ex, ey - Tlen*c, TEAL, 3);
        ctx.fillStyle = TEAL; ctx.font = '11px monospace'; ctx.textAlign = 'left';
        ctx.fillText('T cosθ', ex + 4, ey - Tlen*c + 4);
        ctx.fillStyle = GREEN; ctx.fillText('T', tx + 4, ty);
        // 重さ W(赤・下向き)
        arrow(cx, py+r+36, cx, py+r+60, RED, 2.5);
        ctx.fillStyle = RED; ctx.font = '12px monospace'; ctx.textAlign = 'left';
        ctx.fillText('W', cx + 8, py+r+54);
        // バランス注記
        ctx.fillStyle = '#7d7568'; ctx.font = '11px monospace'; ctx.textAlign = 'center';
        ctx.fillText('上向き合計 2·T cosθ = W', cx, ceil - 18);
        ctx.fillStyle = '#7d7568'; ctx.fillText('θ=' + th + '°', aR + 18, ceil + 14);

        // --- 棒グラフ(右上) ---
        var bx = 430, bw = 230, by = 58, bg = 40, maxV = 2;
        function bar(y, label, val, col){
          ctx.fillStyle = '#7d7568'; ctx.font = '12px monospace'; ctx.textAlign = 'left';
          ctx.fillText(label, bx, y - 6);
          ctx.fillStyle = '#ece7df'; ctx.fillRect(bx, y, bw, 14);
          ctx.fillStyle = col; ctx.fillRect(bx, y, bw * Math.min(1, val/maxV), 14);
          ctx.fillStyle = INK; ctx.textAlign = 'right';
          ctx.fillText('×' + val.toFixed(2), bx + bw, y - 6);
        }
        bar(by,        '必要な力  T/W = 1/(2cosθ)', forceR, RED);
        bar(by + bg,   '引く距離  ロープ/持ち上げ = 2cosθ', distR, TEAL);
        bar(by + 2*bg, '仕事  = 力 × 距離', workR, GREEN);
        ctx.strokeStyle = GREEN; ctx.setLineDash([4,3]); ctx.lineWidth = 1.5;
        var x1 = bx + bw * (1/maxV);
        ctx.beginPath(); ctx.moveTo(x1, by + 2*bg - 6); ctx.lineTo(x1, by + 2*bg + 22); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = GREEN; ctx.font = '11px monospace'; ctx.textAlign = 'center';
        ctx.fillText('いつもここ（一定）', x1, by + 2*bg + 36);

        // --- 「糸を引く量 vs 上がる高さ」可視化（下） ---
        var gy = 300, lift = 46;        // 上がる高さの基準px
        var rope = lift * distR;        // 引く糸 = 2cosθ × lift
        ctx.fillStyle = '#7d7568'; ctx.font = '12px monospace'; ctx.textAlign = 'left';
        ctx.fillText('引いた糸の長さ', 40, gy - lift - 8);
        ctx.fillText('上がる高さ', 250, gy - lift - 8);
        // 引く糸(緑・長い)
        arrow(70, gy, 70, gy - rope, GREEN, 3);
        ctx.fillStyle = GREEN; ctx.textAlign = 'left';
        ctx.fillText('= 2cosθ × 高さ', 84, gy - rope/2);
        // 上がる高さ(青緑・基準)
        arrow(290, gy, 290, gy - lift, TEAL, 3);
        ctx.fillStyle = TEAL; ctx.fillText('= 1 ぶん', 304, gy - lift/2);
        // 基準線
        ctx.strokeStyle = '#d9d2c6'; ctx.lineWidth = 1; ctx.setLineDash([2,2]);
        ctx.beginPath(); ctx.moveTo(40, gy); ctx.lineTo(360, gy); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = '#7d7568'; ctx.font = '11px monospace'; ctx.textAlign = 'left';
        ctx.fillText(th < 30 ? 'θが小さいほど、糸をたくさん引いて少ししか上がらない' : 'θが大きいと、糸も少ししか引かない（力の得も消える）', 40, gy + 22);
      }

      function status(){
        var el = document.getElementById('pul-status');
        var rad = th*Math.PI/180, c = Math.cos(rad);
        var fr = (1/(2*c));
        if(th === 0){
          el.textContent = 'ロープが平行（θ=0）。力は半分 T=W/2、引く距離は2倍、仕事＝W×高さ。これが教科書の動滑車。';
          el.style.color = TEAL;
        } else if(th >= 60){
          el.textContent = 'θ=' + th + '°。cosθ が小さく、必要な力 T=W/(2cosθ)=' + fr.toFixed(2) + '×W。θ=60°では T=W —— 動滑車の利得はゼロ。でも引く距離も同じだけ減って、仕事は W×高さ のまま。「力が半分」は崩れても、仕事＝位置エネルギーの増加は崩れない。';
          el.style.color = RED;
        } else {
          el.textContent = 'θ=' + th + '°。上向きに効くのは 2T·cosθ。必要な力 T=W/(2cosθ)=' + fr.toFixed(2) + '×W に増えた。けれど引くロープは 2cosθ 倍に減り、積（仕事）は W×高さ で一定。力×距離＝位置エネルギーの増加、が不変量。';
          el.style.color = '#7d7568';
        }
      }

      function render(){ draw(); status(); }
      document.getElementById('pul-th').addEventListener('input', function(e){
        th = parseInt(e.target.value, 10);
        document.getElementById('pul-th-v').textContent = th + '°';
        render();
      });
      render();
    })();
    </script>

    <!-- Color space / neutral axis -->
    <div class="app-card">
      <div class="app-title">色空間と中立軸 — グレーの背骨はどこ？</div>
      <div class="app-desc">
        色を「明るさ（縦）× 色味（横）」の断面で見たもの。中央のグレーの線が <b>中立軸</b> ── 色相・彩度・明度を測る基準の背骨だよ（明度＝軸上の位置, 彩度＝軸からの距離, 色相＝どちら側か）。<br>
        ここがこの話の肝：使える色の範囲（色域）は左右非対称だから、<b>「使える色のド真ん中」＝グレー、ではない</b>。中立軸は"形の中心"では決められず、黒からの距離（計量）から導く必要がある ── それが100年解けなかった宿題。「色域のゆがみ」を動かして、真ん中（破線）とグレー軸（実線）がズレるのを見て。
      </div>
      <div class="canvas-label">縦=明度(下が黒,上が白) ／ 横=色味 ／ 実線=中立軸(グレー), 破線=色域の幾何中心</div>
      <canvas id="col-cv" width="720" height="380" style="width:100%;height:auto;cursor:default;"></canvas>
      <div class="controls">
        <div class="ctrl-group">
          <label>色域のゆがみ</label>
          <input type="range" id="col-w" min="0" max="100" value="0">
          <span id="col-w-v">0</span>
        </div>
        <div class="ctrl-group">
          <label>見る明度 L</label>
          <input type="range" id="col-l" min="2" max="98" value="50">
          <span id="col-l-v">0.50</span>
        </div>
      </div>
      <div class="status" id="col-status"></div>
    </div>

    <script is:inline>
    (function(){
      var cv = document.getElementById('col-cv');
      if(!cv) return;
      var ctx = cv.getContext('2d');
      var INK = '#1d1b17';
      var w = 0, Lsel = 0.5;

      var RX = 60, RY = 30, RW = 320, RH = 320;   // 断面の領域
      var CX = RX + 160, HALF = 140;               // グレー軸のx, 横の最大半幅(px)

      function clamp01(v){ return v < 0 ? 0 : v > 1 ? 1 : v; }
      function Bof(L){ return Math.sin(Math.PI * L); }          // その明度で使える色味の幅(0..1)
      function asym(L){ return w * 0.6 * Math.sin(2*Math.PI*L); } // 左右非対称の度合い
      function rfrac(L){ return Bof(L) * (1 + asym(L)); }
      function lfrac(L){ return Bof(L) * (1 - asym(L)); }
      function centerOffsetPx(L){ return Bof(L) * asym(L) * HALF; } // 幾何中心の、グレー軸からのズレ

      function colAt(c, L){ // c: -1..1, L: 0..1
        return [clamp01(L + 0.55*c), clamp01(L - 0.55*c), clamp01(L - 0.15*Math.abs(c))];
      }

      function fillSlice(){
        var img = ctx.createImageData(RW, RH);
        var d = img.data;
        for(var py = 0; py < RH; py++){
          var L = 1 - py / RH;
          var rf = rfrac(L), lf = lfrac(L);
          for(var px = 0; px < RW; px++){
            var cc = ((RX + px) - CX) / HALF;          // -1.6..1.6
            var ef = cc >= 0 ? rf : lf;
            var idx = (py * RW + px) * 4;
            if(ef <= 0){ d[idx+3] = 0; continue; }
            var cn = cc / ef;
            if(cn < -1 || cn > 1){ d[idx+3] = 0; continue; }
            var rgb = colAt(cn, L);
            d[idx] = rgb[0]*255; d[idx+1] = rgb[1]*255; d[idx+2] = rgb[2]*255; d[idx+3] = 255;
          }
        }
        ctx.putImageData(img, RX, RY);
      }

      function yOfL(L){ return RY + (1 - L) * RH; }

      function draw(){
        ctx.clearRect(0,0,cv.width,cv.height);
        fillSlice();

        // 幾何中心（破線）
        ctx.strokeStyle = '#7d7568'; ctx.lineWidth = 1.5; ctx.setLineDash([5,4]);
        ctx.beginPath();
        for(var py = 0; py <= RH; py += 4){
          var L = 1 - py/RH; var x = CX + centerOffsetPx(L); var y = RY + py;
          if(py === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        ctx.stroke(); ctx.setLineDash([]);

        // 中立軸（グレー・実線）
        ctx.strokeStyle = INK; ctx.lineWidth = 2.5;
        ctx.beginPath(); ctx.moveTo(CX, RY); ctx.lineTo(CX, RY + RH); ctx.stroke();
        // 端点(黒・白)
        ctx.fillStyle = '#111'; ctx.beginPath(); ctx.arc(CX, RY + RH, 5, 0, 7); ctx.fill();
        ctx.fillStyle = '#fff'; ctx.strokeStyle = INK; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(CX, RY, 5, 0, 7); ctx.fill(); ctx.stroke();

        // 選んだ明度のスライス
        var y = yOfL(Lsel), rf = rfrac(Lsel), lf = lfrac(Lsel);
        ctx.strokeStyle = 'rgba(29,27,23,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([2,2]);
        ctx.beginPath(); ctx.moveTo(CX - lf*HALF, y); ctx.lineTo(CX + rf*HALF, y); ctx.stroke();
        ctx.setLineDash([]);
        // 中立点
        ctx.fillStyle = '#fff'; ctx.strokeStyle = INK; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(CX, y, 5, 0, 7); ctx.fill(); ctx.stroke();
        // 彩度の矢印
        arrowCol(CX, y, CX + rf*HALF, y, '#3c7876', 2);
        ctx.fillStyle = '#3c7876'; ctx.font = '11px monospace'; ctx.textAlign = 'center';
        ctx.fillText('彩度', CX + rf*HALF*0.5, y - 6);

        // ラベル
        ctx.fillStyle = INK; ctx.font = '11px monospace'; ctx.textAlign = 'left';
        ctx.fillText('中立軸（グレー）', CX + 8, RY + 14);
        ctx.fillStyle = '#7d7568'; ctx.fillText('使える色の真ん中', CX + 8, RY + RH - 8);
        ctx.fillStyle = '#7d7568'; ctx.textAlign = 'center';
        ctx.fillText('白', CX, RY - 8); ctx.fillText('黒', CX, RY + RH + 16);
        ctx.fillStyle = INK; ctx.fillText('← 緑寄り', RX + 50, RY + RH + 16);
        ctx.fillText('赤寄り →', RX + RW - 50, RY + RH + 16);

        // 右パネル
        var tx = 430, ty = 60;
        ctx.textAlign = 'left'; ctx.font = '12px monospace';
        ctx.fillStyle = INK; ctx.fillText('明度 L = ' + Lsel.toFixed(2), tx, ty);
        var offFrac = (centerOffsetPx(Lsel) / HALF);
        ctx.fillStyle = '#7d7568'; ctx.font = '11px monospace';
        ctx.fillText('このスライスで:', tx, ty + 26);
        ctx.fillText('・グレー(中立)はいつも中央の実線上', tx, ty + 46);
        ctx.fillText('・色域の幾何中心は ' + (offFrac>=0?'+':'') + offFrac.toFixed(2) + ' ずれてる', tx, ty + 66);
        ctx.fillStyle = (Math.abs(offFrac) < 0.01) ? '#2f9e6e' : '#c2543d';
        ctx.fillText(Math.abs(offFrac) < 0.01 ? '→ 真ん中＝グレー（一致）' : '→ 真ん中 ≠ グレー（ズレてる）', tx, ty + 88);
      }

      function arrowCol(x0,y0,x1,y1,col,lw){
        ctx.strokeStyle=col;ctx.fillStyle=col;ctx.lineWidth=lw;
        ctx.beginPath();ctx.moveTo(x0,y0);ctx.lineTo(x1,y1);ctx.stroke();
        var a=Math.atan2(y1-y0,x1-x0),h=6;
        ctx.beginPath();ctx.moveTo(x1,y1);
        ctx.lineTo(x1-h*Math.cos(a-0.4),y1-h*Math.sin(a-0.4));
        ctx.lineTo(x1-h*Math.cos(a+0.4),y1-h*Math.sin(a+0.4));
        ctx.closePath();ctx.fill();
      }

      function status(){
        var el = document.getElementById('col-status');
        if(w < 0.01){
          el.textContent = 'ゆがみ無し：使える色が左右対称だから、色域の真ん中（破線）＝グレー（実線）でぴったり一致する。これなら中立軸は"形の中心"で済む（リーマン的）。';
          el.style.color = '#2f9e6e';
        } else {
          el.textContent = 'ゆがみ有り：色域が左右非対称になり、"使える色の真ん中"（破線）がグレー軸（実線）からズレた。だから中立軸は形の中心では決められず、黒からの距離（計量）で定義する必要がある —— これがシュレーディンガーの宿題で、非リーマン幾何で解かれた部分だよ。';
          el.style.color = '#c2543d';
        }
      }

      function render(){ draw(); status(); }
      document.getElementById('col-w').addEventListener('input', function(e){
        w = parseInt(e.target.value,10)/100;
        document.getElementById('col-w-v').textContent = e.target.value;
        render();
      });
      document.getElementById('col-l').addEventListener('input', function(e){
        Lsel = parseInt(e.target.value,10)/100;
        document.getElementById('col-l-v').textContent = Lsel.toFixed(2);
        render();
      });
      render();
    })();
    </script>

    <!-- Hue: line to circle (S^1) -->
    <div class="app-card">
      <div class="app-title">色相は円になる — 物理の「線」が知覚の「輪」へ</div>
      <div class="app-desc">
        物理の波長は、紫(380nm)から赤(700nm)までの<b>一本の線</b>でしかない。両端は別の色で、つながっていない。<br>
        でも知覚は、スペクトルに無い<b>紫（マゼンタ＝赤と青紫の混色）</b>で両端を糊づけして、<b>輪（色相環 S¹）</b>に閉じてしまう。スライダーを動かすと、線が曲がって円になり、間を非スペクトルの紫が埋めるのが見える。位相が「物理」から「知覚」へ移るときに変わる、いい例だよ。
      </div>
      <div class="canvas-label">スライダー：線（波長） → 円（色相環）</div>
      <canvas id="hue-cv" width="720" height="380" style="width:100%;height:auto;cursor:default;"></canvas>
      <div class="controls">
        <div class="ctrl-group">
          <label>線 → 円</label>
          <input type="range" id="hue-m" min="0" max="100" value="0">
          <span id="hue-m-v">0%</span>
        </div>
        <button class="btn" id="hue-go" type="button">アニメ ▶</button>
      </div>
      <div class="status" id="hue-status"></div>
    </div>

    <script is:inline>
    (function(){
      var cv = document.getElementById('hue-cv');
      if(!cv) return;
      var ctx = cv.getContext('2d');
      var m = 0, timer = null;
      var cx = 235, cy = 205, R = 135, xLeft = 80, Lw = 310, yLine = 205;
      var FS = 0.80, UCUT = (FS + 1) / 2;   // 紫の真ん中で切って線にする

      function wl2rgb(wl){
        var r=0,g=0,b=0;
        if(wl>=380&&wl<440){r=-(wl-440)/60;b=1;}
        else if(wl<490){g=(wl-440)/50;b=1;}
        else if(wl<510){g=1;b=-(wl-510)/20;}
        else if(wl<580){r=(wl-510)/70;g=1;}
        else if(wl<645){r=1;g=-(wl-645)/65;}
        else {r=1;}
        var f=1;
        if(wl<420)f=0.3+0.7*(wl-380)/40;
        else if(wl>700)f=0.3+0.7*(780-wl)/80;
        return [r*f,g*f,b*f];
      }
      function colOfU(u){
        if(u < FS){ var wl = 700 - (u/FS)*320; return wl2rgb(wl); }
        var t = (u-FS)/(1-FS);                 // 0(紫端)→1(赤端)
        var v = wl2rgb(410), rr = wl2rgb(680);
        return [v[0]+(rr[0]-v[0])*t, v[1]+(rr[1]-v[1])*t, v[2]+(rr[2]-v[2])*t];
      }
      function ease(x){ return x*x*(3-2*x); }

      function posLine(s){ return [xLeft + s*Lw, yLine]; }
      function posCircle(s){ var a = s*2*Math.PI - Math.PI/2; return [cx + R*Math.cos(a), cy + R*Math.sin(a)]; }
      function pos(s){
        var e = ease(m), L = posLine(s), C = posCircle(s);
        return [L[0]+(C[0]-L[0])*e, L[1]+(C[1]-L[1])*e];
      }

      function draw(){
        ctx.clearRect(0,0,cv.width,cv.height);
        var N = 260;
        ctx.lineWidth = 16; ctx.lineCap = 'round';
        for(var i=0;i<N;i++){
          var s0=i/N, s1=(i+1)/N;
          var u=(s0+UCUT)%1;
          var isPurple = u >= FS;
          var rgb = colOfU(u);
          var p0=pos(s0), p1=pos(s1);
          ctx.globalAlpha = isPurple ? (0.18 + 0.82*ease(m)) : 1;  // 紫は知覚が足す→mで濃くなる
          ctx.strokeStyle = 'rgb('+(rgb[0]*255|0)+','+(rgb[1]*255|0)+','+(rgb[2]*255|0)+')';
          ctx.beginPath(); ctx.moveTo(p0[0],p0[1]); ctx.lineTo(p1[0],p1[1]); ctx.stroke();
        }
        ctx.globalAlpha = 1;

        // 端のラベル（赤端・紫端）
        function uToS(u){ return ((u-UCUT+1)%1); }
        function labelAt(u, text, col){
          var p = pos(uToS(u));
          ctx.fillStyle = col; ctx.font = '12px monospace'; ctx.textAlign = 'center';
          ctx.fillText(text, p[0], p[1] - 16);
        }
        labelAt(0.001, '赤 700nm', '#b03020');
        labelAt(FS-0.001, '紫 380nm', '#5030a0');

        // 非スペクトルの紫の注記
        var pmid = pos(uToS((FS+1)/2 % 1));
        ctx.fillStyle = '#9030a0'; ctx.font = '11px monospace'; ctx.textAlign = 'center';
        ctx.fillText('非スペクトルの紫', pmid[0], pmid[1] + (m>0.5? -22 : 30));
        ctx.fillText('（知覚が足す）', pmid[0], pmid[1] + (m>0.5? -10 : 42));

        // 中央の注記
        ctx.fillStyle = '#7d7568'; ctx.font = '12px monospace'; ctx.textAlign = 'center';
        if(m < 0.05) ctx.fillText('線（区間）', cx, 360);
        else if(m > 0.95) ctx.fillText('輪（S¹）', cx, cy);
      }

      function status(){
        var el = document.getElementById('hue-status');
        if(m < 0.05){
          el.textContent = '物理の波長：紫(380nm)から赤(700nm)までの一本の線。両端は別の色で、つながっていない。区間（線）だよ。';
          el.style.color = '#7d7568';
        } else if(m > 0.95){
          el.textContent = '知覚：赤端と紫端を「非スペクトルの紫（マゼンタ）」で糊づけして、輪に閉じた。これが色相環＝S¹。物理には無い紫が、線を円に変えてる —— 位相そのものが、物理から知覚へ移るときに変わった例だよ。';
          el.style.color = '#9030a0';
        } else {
          el.textContent = '曲げているところ…赤端と紫端が近づいて、その間を「物理には無い紫」が埋めていく。線が輪になる途中。';
          el.style.color = '#7d7568';
        }
      }

      function render(){ draw(); status(); }
      function setM(v){
        m = v;
        document.getElementById('hue-m').value = Math.round(v*100);
        document.getElementById('hue-m-v').textContent = Math.round(v*100) + '%';
        render();
      }
      document.getElementById('hue-m').addEventListener('input', function(e){
        if(timer){ clearInterval(timer); timer=null; }
        setM(parseInt(e.target.value,10)/100);
      });
      document.getElementById('hue-go').addEventListener('click', function(){
        if(timer){ clearInterval(timer); timer=null; return; }
        var dir = (m >= 0.99) ? -1 : 1;
        timer = setInterval(function(){
          var nv = m + dir*0.02;
          if(nv >= 1){ nv = 1; clearInterval(timer); timer=null; }
          if(nv <= 0){ nv = 0; clearInterval(timer); timer=null; }
          setM(nv);
        }, 30);
      });
      render();
    })();
    </script>

    <!-- Fourier Sketchbook -->
    <div class="app-card">
      <div class="app-title">Fourier スケッチブック</div>
      <div class="app-desc">
        左のキャンバスにマウスで形を描くと、回転する円（エピサイクル）の重ね合わせが元の形を再現する。<br>
        フーリエ級数は「任意の周期関数を正弦波の和で表せる」という話で、これはその可視化。RFでいえば、任意の波形をスペクトルに分解してまた足し合わせるようなもの。
      </div>

      <div class="fourier-wrap">
        <div>
          <div class="canvas-label">INPUT — ここに描く</div>
          <canvas id="cv-draw" width="340" height="340"></canvas>
        </div>
        <div>
          <div class="canvas-label">OUTPUT — エピサイクル</div>
          <canvas id="cv-epi" width="340" height="340"></canvas>
        </div>
      </div>
      <div style="margin-top:1rem;">
        <div class="canvas-label">SPECTRUM — 周波数成分の振幅（明るいバー = 今回転中の円）</div>
        <canvas id="cv-spec-f" width="700" height="100" style="width:100%;height:100px;border-radius:10px;border:1px solid var(--border,#e3dbd0);background:#faf8f4;"></canvas>
      </div>
      <div>
      </div>

      <div class="controls">
        <div class="ctrl-group">
          <label>N（高調波数）</label>
          <input type="range" id="n-harmonics" min="1" max="128" value="32">
          <span id="n-val">32</span>
        </div>
        <div class="ctrl-group">
          <label>速度</label>
          <input type="range" id="speed" min="1" max="20" value="6">
          <span id="speed-val">6</span>
        </div>
        <button class="btn primary" id="btn-clear">クリア</button>
        <button class="btn" id="btn-pause">一時停止</button>
      </div>

      <div class="presets">
        <span style="font-size:.68rem;font-family:'JetBrains Mono',monospace;color:var(--text-faint,#aaa49b);margin-right:.2rem;">プリセット:</span>
        <button class="preset-btn" data-shape="square">矩形波</button>
        <button class="preset-btn" data-shape="triangle">三角波</button>
        <button class="preset-btn" data-shape="sawtooth">ノコギリ波</button>
        <button class="preset-btn" data-shape="circle">円</button>
        <button class="preset-btn" data-shape="lemniscate">∞</button>
        <button class="preset-btn" data-shape="rf">RF↯</button>
      </div>

