---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="ja">
<head>
  <BaseHead title="声の地図 — 母音とフォルマント" description="「あいうえお」は声道の共鳴(フォルマント F1・F2)の置き場所で決まる。F1–F2平面の点をドラッグすると母音が変わって音も鳴る。声帯のブザーをF1/F2/F3のバンドパスに通すフォルマント合成。" />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style is:global>
    .intro{background:var(--card,#fff);border:1px solid var(--border,#e3dbd0);border-radius:14px;
      padding:1.5rem 1.75rem;margin-bottom:2rem;box-shadow:0 1px 6px rgba(29,27,23,.05);}
    .intro h1{font-size:1.25rem;margin:0 0 .5rem;}
    .intro p{font-size:.9rem;color:var(--text-muted,#7d7568);line-height:1.75;margin:0 0 .4rem;}
    .intro a{color:#3c7876;}
    .card{background:var(--card,#fff);border:1px solid var(--border,#e3dbd0);border-radius:14px;
      padding:1.5rem;margin-bottom:2rem;box-shadow:0 1px 6px rgba(29,27,23,.05);}
    canvas{border:1px solid var(--border,#e3dbd0);border-radius:10px;display:block;background:#faf8f4;
      width:100%;height:auto;touch-action:none;cursor:crosshair;}
    .controls{display:flex;flex-wrap:wrap;gap:.7rem;align-items:center;margin-top:1rem;}
    .ctrl-group{display:flex;align-items:center;gap:.5rem;}
    .ctrl-group label{font-size:.72rem;font-family:'JetBrains Mono',monospace;color:var(--text-muted,#7d7568);white-space:nowrap;}
    .ctrl-group input[type=range]{width:120px;accent-color:#3c7876;}
    .btn{padding:.38rem .9rem;border:1px solid var(--border,#e3dbd0);border-radius:8px;background:none;
      font-family:inherit;font-size:.82rem;color:var(--text-muted,#7d7568);cursor:pointer;transition:all .15s;}
    .btn:hover{border-color:#3c7876;color:#3c7876;}
    .btn.primary{background:#3c7876;color:#fff;border-color:#3c7876;}
    .vows{display:flex;gap:.5rem;flex-wrap:wrap;}
    .vbtn{width:2.4rem;height:2.4rem;border:1px solid var(--border,#e3dbd0);border-radius:10px;background:var(--surface,#faf8f4);
      font-size:1.15rem;font-weight:700;color:#33433f;cursor:pointer;transition:all .12s;font-family:'Zen Kaku Gothic New',sans-serif;}
    .vbtn:hover{border-color:#3c7876;color:#3c7876;transform:translateY(-1px);}
    .readout{margin-top:1rem;background:var(--surface,#faf8f4);border:1px solid var(--border,#e3dbd0);
      border-radius:10px;padding:.85rem 1.1rem;}
    .readout .big{font-family:'Zen Kaku Gothic New',sans-serif;font-size:1.7rem;font-weight:700;color:#3c7876;}
    .readout .nums{font-family:'JetBrains Mono',monospace;font-size:.86rem;color:#2a4d49;margin-top:.2rem;}
    .status{font-size:.72rem;font-family:'JetBrains Mono',monospace;color:var(--text-faint,#aaa49b);margin-top:.7rem;}
  </style>
</head>
<body>
  <Header />
  <main class="wrap">
    <div class="intro">
      <h1>声の地図 — 母音とフォルマント</h1>
      <p>「あいうえお」の違いは、のどの高さでも舌の形そのものでもなく、<strong>声道の共鳴のピークがどこに立つか</strong>で決まる。低いほうから F1・F2 と呼ぶ2つの山の置き場所、ほぼこれだけで母音が決まってしまう。</p>
      <p>下の地図は横が <strong>F2</strong>（舌の前後）、縦が <strong>F1</strong>（口の開き）。点をドラッグすると、声帯のブザー（のこぎり波）を F1・F2・F3 のバンドパスに通した音が鳴る——これが<strong>フォルマント合成</strong>。「い」のあたりに動かすと「いー」に聞こえる。あ・い・う・え・お の位置も置いてあるよ。<a href="/play">← /play に戻る</a></p>
    </div>

    <div class="card">
      <canvas id="cv" width="680" height="430"></canvas>
      <div class="controls">
        <button class="btn primary" id="play" type="button">▶ 鳴らす</button>
        <button class="btn" id="stop" type="button">■ 止める</button>
        <div class="vows" id="vows" style="margin-left:.3rem;"></div>
        <div class="ctrl-group" style="margin-left:auto;"><label>声の高さ</label><input type="range" id="pitch" min="80" max="200" value="120"><span id="pitchv" style="font-family:'JetBrains Mono',monospace;font-size:.74rem;color:#3c7876;font-weight:700;">120Hz</span></div>
      </div>
      <div class="readout" id="readout"></div>
      <div class="status" id="status">地図をドラッグ（スマホはタップして動かす）すると音が出る。あ・い・う・え・お のボタンでその母音へ。</div>
    </div>

    <div class="card">
      <div style="font-size:.84rem;color:#7d7568;margin-bottom:.7rem;line-height:1.7;">なぜ F1・F2 なのか——声道は <b>声帯側が閉じた1本の管</b>で、その共鳴のいちばん低い2つが F1・F2 だ。下の管はいまの母音の形。舌や唇でできる <b style="color:#c9761f">くびれ</b> の場所・深さが変わると、共鳴（＝F1・F2）がずれて別の母音になる。<span style="color:#c2543d">赤</span>＝F1の定在波（1/4波長）、<span style="color:#3a6df0">青</span>＝F2（3/4波長）。地図を動かすと管も連動するよ。</div>
      <canvas id="tube" width="680" height="180"></canvas>
    </div>
  </main>
  <Footer />

<script is:inline>
(function(){
  var cv=document.getElementById('cv'), ctx=cv.getContext('2d');
  var tcv=document.getElementById('tube'), tctx=tcv.getContext('2d');
  function lerp(a,b,t){ return a+(b-a)*t; }
  function mapc(v,a,b,c,d){ var t=(v-a)/(b-a); t=t<0?0:t>1?1:t; return c+(d-c)*t; }
  var TEAL='#3c7876', WARM='#c9761f', GRAY='#aaa49b', LINE='#e3dbd0', INK='#1d1b17', MUT='#7d7568';

  var MX0=58, MX1=622, MY0=40, MY1=312;
  var F2L=2600, F2R=600, F1T=200, F1B=950;
  var EX0=58, EX1=622, EY0=350, EY1=414, FMAX=3600;
  function f2x(f){ return MX0 + (F2L-f)/(F2L-F2R)*(MX1-MX0); }
  function f1y(f){ return MY0 + (f-F1T)/(F1B-F1T)*(MY1-MY0); }
  function x2f2(x){ return F2L - (x-MX0)/(MX1-MX0)*(F2L-F2R); }
  function y2f1(y){ return F1T + (y-MY0)/(MY1-MY0)*(F1B-F1T); }
  function clamp(v,a,b){ return v<a?a:v>b?b:v; }

  var VOW=[['あ',800,1300],['い',300,2300],['う',350,1250],['え',500,1900],['お',500,900]];
  var F3=2900;
  var F1=620, F2=1200, pitch=120;

  var actx=null, osc=null, bands=[], master=null, playing=false;
  function ensureAudio(){
    if(actx) return;
    var AC=window.AudioContext||window.webkitAudioContext; if(!AC) return;
    actx=new AC();
    osc=actx.createOscillator(); osc.type='sawtooth'; osc.frequency.value=pitch;
    master=actx.createGain(); master.gain.value=0; master.connect(actx.destination);
    var Q=[9,11,13], G=[1.0,0.62,0.26];
    for(var i=0;i<3;i++){
      var b=actx.createBiquadFilter(); b.type='bandpass'; b.Q.value=Q[i];
      var g=actx.createGain(); g.gain.value=G[i];
      osc.connect(b); b.connect(g); g.connect(master); bands.push(b);
    }
    osc.start();
    pushAudio();
  }
  function pushAudio(){ if(!actx) return; bands[0].frequency.value=F1; bands[1].frequency.value=F2; bands[2].frequency.value=F3; osc.frequency.value=pitch; }
  function start(){ ensureAudio(); if(!actx) return; if(actx.state==='suspended') actx.resume(); pushAudio(); master.gain.setTargetAtTime(0.55, actx.currentTime, 0.02); playing=true; setStatus(); }
  function stop(){ if(!actx) return; master.gain.setTargetAtTime(0, actx.currentTime, 0.04); playing=false; setStatus(); }

  function nearest(){ var best=null,bd=1e9; for(var i=0;i<VOW.length;i++){ var dx=(F2-VOW[i][2])/1000, dy=(F1-VOW[i][1])/1000, d=dx*dx+dy*dy; if(d<bd){bd=d;best=VOW[i];} } return {v:best, d:Math.sqrt(bd)}; }

  function draw(){
    ctx.clearRect(0,0,cv.width,cv.height);
    ctx.fillStyle='#fff'; ctx.fillRect(MX0,MY0,MX1-MX0,MY1-MY0);
    ctx.strokeStyle=LINE; ctx.lineWidth=1; ctx.strokeRect(MX0+.5,MY0+.5,MX1-MX0,MY1-MY0);
    ctx.fillStyle=GRAY; ctx.font='10px "JetBrains Mono",monospace';
    ctx.strokeStyle='#f0ebe2';
    var f2;
    for(f2=600;f2<=2600;f2+=400){ var x=f2x(f2); ctx.beginPath(); ctx.moveTo(x,MY0); ctx.lineTo(x,MY1); ctx.stroke(); ctx.textAlign='center'; ctx.fillText(f2, x, MY0-5); }
    var f1;
    for(f1=200;f1<=950;f1+=150){ var y=f1y(f1); ctx.beginPath(); ctx.moveTo(MX0,y); ctx.lineTo(MX1,y); ctx.stroke(); ctx.textAlign='right'; ctx.fillText(f1, MX0-5, y+3); }
    ctx.fillStyle=MUT; ctx.font='600 11px "JetBrains Mono",monospace'; ctx.textAlign='center';
    ctx.fillText('← F2 (Hz)  舌:前  /  後 →', (MX0+MX1)/2, MY1+18);
    ctx.save(); ctx.translate(MX0-34,(MY0+MY1)/2); ctx.rotate(-Math.PI/2); ctx.fillText('← F1 (Hz)  口:閉じ / 開き →',0,0); ctx.restore();
    for(var i=0;i<VOW.length;i++){ var vx=f2x(VOW[i][2]), vy=f1y(VOW[i][1]);
      ctx.fillStyle='rgba(60,120,118,.10)'; ctx.beginPath(); ctx.arc(vx,vy,20,0,7); ctx.fill();
      ctx.fillStyle=TEAL; ctx.font='700 19px "Zen Kaku Gothic New",sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(VOW[i][0], vx, vy);
    }
    ctx.textBaseline='alphabetic';
    var px=f2x(F2), py=f1y(F1);
    ctx.strokeStyle=WARM; ctx.lineWidth=2; ctx.beginPath(); ctx.arc(px,py,11,0,7); ctx.stroke();
    ctx.fillStyle='rgba(201,118,31,.22)'; ctx.beginPath(); ctx.arc(px,py,11,0,7); ctx.fill();
    ctx.fillStyle=WARM; ctx.beginPath(); ctx.arc(px,py,3.5,0,7); ctx.fill();

    ctx.fillStyle='#fff'; ctx.fillRect(EX0,EY0,EX1-EX0,EY1-EY0);
    ctx.strokeStyle=LINE; ctx.strokeRect(EX0+.5,EY0+.5,EX1-EX0,EY1-EY0);
    ctx.fillStyle=GRAY; ctx.font='10px "JetBrains Mono",monospace'; ctx.textAlign='left';
    ctx.fillText('声道の共鳴（フォルマント包絡）', EX0+4, EY0-5);
    function ex(f){ return EX0 + f/FMAX*(EX1-EX0); }
    var fs=[F1,F2,F3], bw=[90,110,150], amp=[1.0,0.62,0.30];
    ctx.strokeStyle=TEAL; ctx.lineWidth=2; ctx.beginPath();
    for(var sx=0; sx<=(EX1-EX0); sx+=2){ var f=sx/(EX1-EX0)*FMAX, v=0;
      for(var k=0;k<3;k++){ var d=(f-fs[k])/bw[k]; v+=amp[k]/(1+d*d); }
      var yy=EY1-2 - Math.min(1,v)*(EY1-EY0-6);
      if(sx===0)ctx.moveTo(EX0+sx,yy); else ctx.lineTo(EX0+sx,yy);
    }
    ctx.stroke();
    var labs=['F1','F2','F3'];
    for(var k=0;k<3;k++){ var fx=ex(fs[k]); ctx.strokeStyle='rgba(201,118,31,.5)'; ctx.setLineDash([3,3]); ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(fx,EY0+2); ctx.lineTo(fx,EY1-2); ctx.stroke(); ctx.setLineDash([]);
      ctx.fillStyle=WARM; ctx.font='10px "JetBrains Mono",monospace'; ctx.textAlign='center'; ctx.fillText(labs[k], fx, EY0+12); }
  }

  function setReadout(){
    var n=nearest();
    var name = n.d<0.28 ? n.v[0] : '（中間）';
    document.getElementById('readout').innerHTML =
      '<span class="big">'+name+'</span>'+
      '<div class="nums">F1 = '+Math.round(F1)+' Hz ／ F2 = '+Math.round(F2)+' Hz ／ F3 = '+F3+' Hz　'+
      (n.d<0.28? '（「'+n.v[0]+'」に近い）' : '（あ〜お の間の音）')+'</div>';
  }
  function setStatus(){ document.getElementById('status').textContent =
    (playing?'♪ 鳴らしてる':'停止中')+'　— のこぎり波 '+pitch+'Hz を F1/F2/F3 のバンドパスに通したフォルマント合成。地図をドラッグで母音が変わる。'; }

  function drawTube(){
    var W=tcv.width, H=tcv.height; tctx.clearRect(0,0,W,H);
    var GL=78, GR=W-26, cy=H/2-4, R0=46;
    var cpos=mapc(F2, 900, 2300, 0.22, 0.84);
    var deg=mapc(F1, 300, 820, 0.72, 0.06);
    function rad(t){ return R0*(1 - deg*Math.exp(-Math.pow((t-cpos)/0.15,2))); }
    var N=120, i, t, x;
    tctx.fillStyle='rgba(201,160,122,.12)'; tctx.strokeStyle='#c9a07a'; tctx.lineWidth=2;
    tctx.beginPath(); tctx.moveTo(GL, cy-rad(0));
    for(i=0;i<=N;i++){ t=i/N; x=lerp(GL,GR,t); tctx.lineTo(x, cy-rad(t)); }
    for(i=N;i>=0;i--){ t=i/N; x=lerp(GL,GR,t); tctx.lineTo(x, cy+rad(t)); }
    tctx.closePath(); tctx.fill(); tctx.stroke();
    tctx.strokeStyle='#8a6a4a'; tctx.lineWidth=3; tctx.beginPath(); tctx.moveTo(GL, cy-rad(0)-4); tctx.lineTo(GL, cy+rad(0)+4); tctx.stroke();
    tctx.fillStyle='#7d7568'; tctx.font='11px "JetBrains Mono",monospace'; tctx.textAlign='center';
    tctx.fillText('声帯（閉）', GL, cy+R0+26); tctx.fillText('唇（開）', GR-6, cy+R0+26);
    function waveDraw(mult,col){ tctx.strokeStyle=col; tctx.lineWidth=2; tctx.beginPath();
      for(i=0;i<=N;i++){ t=i/N; x=lerp(GL,GR,t); var amp=Math.cos(mult*Math.PI*t)*(R0-10);
        if(i===0)tctx.moveTo(x,cy-amp); else tctx.lineTo(x,cy-amp); }
      tctx.stroke(); }
    waveDraw(0.5,'#c2543d'); waveDraw(1.5,'#3a6df0');
    tctx.font='10px "JetBrains Mono",monospace';
    tctx.fillStyle='#c2543d'; tctx.textAlign='left'; tctx.fillText('赤 F1 (1/4波長)', GL+4, cy-R0-4);
    tctx.fillStyle='#3a6df0'; tctx.textAlign='right'; tctx.fillText('青 F2 (3/4波長)', GR-2, cy-R0-4);
    if(deg>0.14){ var cx=lerp(GL,GR,cpos); tctx.fillStyle='#c9761f'; tctx.textAlign='center'; tctx.fillText('くびれ', cx, cy-rad(cpos)-6); }
  }
  function render(){ draw(); drawTube(); setReadout(); }

  function setFromXY(cx,cy){
    var r=cv.getBoundingClientRect(); var sx=(cx-r.left)*(cv.width/r.width), sy=(cy-r.top)*(cv.height/r.height);
    F2=clamp(x2f2(clamp(sx,MX0,MX1)), F2R, F2L);
    F1=clamp(y2f1(clamp(sy,MY0,MY1)), F1T, F1B);
    pushAudio(); render();
  }
  var drag=false;
  cv.addEventListener('pointerdown', function(e){ drag=true; cv.setPointerCapture(e.pointerId); start(); setFromXY(e.clientX,e.clientY); });
  cv.addEventListener('pointermove', function(e){ if(drag) setFromXY(e.clientX,e.clientY); });
  cv.addEventListener('pointerup', function(){ drag=false; });
  cv.addEventListener('pointercancel', function(){ drag=false; });

  function gotoVowel(v, animate){
    var tF1=v[1], tF2=v[2];
    if(animate){ var s0F1=F1,s0F2=F2,t0=performance.now();
      (function step(t){ var k=Math.min(1,(t-t0)/260); var e=k*k*(3-2*k);
        F1=s0F1+(tF1-s0F1)*e; F2=s0F2+(tF2-s0F2)*e; pushAudio(); render();
        if(k<1) requestAnimationFrame(step); })(t0);
    } else { F1=tF1; F2=tF2; pushAudio(); render(); }
  }

  var vw=document.getElementById('vows');
  VOW.forEach(function(v){ var b=document.createElement('button'); b.className='vbtn'; b.textContent=v[0];
    b.onclick=function(){ start(); gotoVowel(v, true); }; vw.appendChild(b); });

  document.getElementById('play').onclick=function(){ start(); };
  document.getElementById('stop').onclick=function(){ stop(); };
  var pt=document.getElementById('pitch'), ptv=document.getElementById('pitchv');
  pt.oninput=function(){ pitch=+pt.value; ptv.textContent=pitch+'Hz'; pushAudio(); setStatus(); };

  render(); setStatus();
})();
</script>
</body>
</html>
