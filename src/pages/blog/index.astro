---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const postMeta = posts.map((p) => ({ slug: p.id, title: p.data.title }));
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`記事一覧 — ${SITE_TITLE}`} description="ランキンが書いた記事の一覧。" />
		<style>
			.section-title {
				font-size: 0.72rem; font-weight: 700;
				color: var(--text-faint); margin-bottom: 1.25rem;
				letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace;
				display: flex; align-items: center; gap: 0.6rem;
				text-transform: uppercase;
			}
			.section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

			ul { list-style: none; display: flex; flex-direction: column; gap: 0.875rem; margin: 0; padding: 0; }
			.post-card {
				display: flex; gap: 1.25rem;
				background: var(--card); border: 1px solid var(--border);
				border-radius: 14px; padding: 1.2rem;
				text-decoration: none; color: var(--text);
				transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
				box-shadow: 0 1px 6px var(--shadow);
			}
			.post-card:hover {
				border-color: var(--accent);
				transform: translateX(3px);
				box-shadow: 0 4px 16px var(--shadow);
				opacity: 1;
			}
			.post-img { width: 96px; flex-shrink: 0; }
			.post-img img { width: 96px; height: 68px; object-fit: cover; border-radius: 8px; margin: 0; }
			.post-body { flex: 1; min-width: 0; }
			.post-date { font-size: 0.75rem; color: var(--text-faint); font-family: 'JetBrains Mono', monospace; margin-bottom: 0.3rem; }
			.post-title { font-weight: 700; font-size: 0.97rem; margin-bottom: 0.35rem; color: var(--text); }
			.post-desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.5; }
			.views { color: var(--accent); margin-left: 0.5rem; }

			.popular { width: 100%; box-sizing: border-box; margin: 0 0 2.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 0.9rem 1.1rem; box-shadow: 0 1px 6px var(--shadow); text-align: left; }
			.popular-title { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; color: var(--accent); font-family: 'JetBrains Mono', monospace; display: block; margin-bottom: 0.6rem; }
			.popular-list { display: flex; flex-direction: column; gap: 0.3rem; }
			.popular-item { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; padding: 0.3rem 0.35rem; border-radius: 7px; }
			.popular-item:hover { background: var(--accent-dim); }
			.popular-rank { font-family: 'JetBrains Mono', monospace; font-weight: 700; color: var(--accent); width: 1.2rem; text-align: center; flex-shrink: 0; }
			.popular-name { flex: 1; color: var(--text); font-size: 0.9rem; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
			.popular-n { color: var(--text-faint); font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; flex-shrink: 0; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h2 class="section-title">記事一覧（全{posts.length}件）</h2>
				<div class="popular" id="popular" hidden>
					<span class="popular-title">🔥 よく読まれている記事</span>
					<div class="popular-list" id="popular-list"></div>
				</div>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-card">
									{post.data.heroImage && (
										<div class="post-img">
											<img src={post.data.heroImage} alt="" />
										</div>
									)}
									<div class="post-body">
										<div class="post-date">
											<FormattedDate date={post.data.pubDate} />
											<span class="views" data-slug={post.id} />
										</div>
										<div class="post-title">{post.data.title}</div>
										<div class="post-desc">{post.data.description}</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<script define:vars={{ postMeta }}>
			// 閲覧数を取得して、各カードに表示＋人気ランキングを作る
			(() => {
				const API = 'https://feedback.tnks1407.com';
				fetch(API + '/views')
					.then((r) => r.json())
					.then((views) => {
						document.querySelectorAll('.views[data-slug]').forEach((el) => {
							const n = views[el.dataset.slug];
							if (typeof n === 'number' && n > 0) el.textContent = '👁 ' + n.toLocaleString();
						});
						const ranked = postMeta
							.map((p) => ({ ...p, n: views[p.slug] || 0 }))
							.filter((p) => p.n > 0)
							.sort((a, b) => b.n - a.n)
							.slice(0, 3);
						if (ranked.length) {
							const list = document.getElementById('popular-list');
							ranked.forEach((p, i) => {
								const a = document.createElement('a');
								a.className = 'popular-item';
								a.href = '/blog/' + p.slug + '/';
								const rank = document.createElement('span');
								rank.className = 'popular-rank';
								rank.textContent = String(i + 1);
								const name = document.createElement('span');
								name.className = 'popular-name';
								name.textContent = p.title;
								const num = document.createElement('span');
								num.className = 'popular-n';
								num.textContent = '👁 ' + p.n.toLocaleString();
								a.append(rank, name, num);
								list.appendChild(a);
							});
							document.getElementById('popular').hidden = false;
						}
					})
					.catch(() => {});
			})();
		</script>
	</body>
</html>
