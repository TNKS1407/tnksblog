---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="ja">
<head>
  <BaseHead title="畳み込みを一歩ずつ — tnkblog" description="12×12の小さな画像で、ぼかしやエッジ（Sobel/Prewitt/ラプラシアンほか）の計算が一マスずつ進む様子を、カーネル行列ごと見る。" />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style is:global>
    .intro{background:var(--card,#fff);border:1px solid var(--border,#e3dbd0);border-radius:14px;
      padding:1.5rem 1.75rem;margin-bottom:2rem;box-shadow:0 1px 6px rgba(29,27,23,.05);}
    .intro h1{font-size:1.25rem;margin:0 0 .5rem;}
    .intro p{font-size:.9rem;color:var(--text-muted,#7d7568);line-height:1.75;margin:0 0 .4rem;}
    .intro a{color:#3c7876;}
    .card{background:var(--card,#fff);border:1px solid var(--border,#e3dbd0);border-radius:14px;
      padding:1.5rem;margin-bottom:2rem;box-shadow:0 1px 6px rgba(29,27,23,.05);}
    canvas{border:1px solid var(--border,#e3dbd0);border-radius:10px;display:block;background:#faf8f4;
      width:100%;height:auto;}
    .ops{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;}
    .opill{padding:.35rem .85rem;border:1px solid var(--border,#e3dbd0);border-radius:999px;
      background:var(--surface,#faf8f4);font-size:.76rem;color:var(--text-muted,#7d7568);cursor:pointer;
      font-family:'JetBrains Mono',monospace;transition:all .12s;}
    .opill:hover{border-color:#3c7876;color:#3c7876;}
    .opill.on{background:#3c7876;color:#fff;border-color:#3c7876;font-weight:700;}
    .controls{display:flex;flex-wrap:wrap;gap:.7rem;align-items:center;margin-top:1rem;}
    .ctrl-group{display:flex;align-items:center;gap:.5rem;}
    .ctrl-group label{font-size:.72rem;font-family:'JetBrains Mono',monospace;color:var(--text-muted,#7d7568);white-space:nowrap;}
    .ctrl-group input[type=range]{width:90px;accent-color:#3c7876;}
    .btn{padding:.35rem .85rem;border:1px solid var(--border,#e3dbd0);border-radius:8px;background:none;
      font-family:inherit;font-size:.78rem;color:var(--text-muted,#7d7568);cursor:pointer;transition:all .15s;}
    .btn:hover{border-color:#3c7876;color:#3c7876;}
    .btn.on{background:#3c7876;color:#fff;border-color:#3c7876;font-weight:700;}
    .readout{margin-top:1rem;background:var(--surface,#faf8f4);border:1px solid var(--border,#e3dbd0);
      border-radius:10px;padding:1rem 1.1rem;min-height:7em;}
    .rhead{font-family:'JetBrains Mono',monospace;font-size:.74rem;color:#3c7876;font-weight:700;margin-bottom:.7rem;}
    .matview{display:flex;flex-wrap:wrap;align-items:center;gap:.45rem .65rem;}
    .mblock{text-align:center;}
    .mlab{font-size:.64rem;color:var(--text-muted,#7d7568);margin-bottom:.25rem;font-family:'JetBrains Mono',monospace;}
    .m3{display:grid;grid-template-columns:repeat(3,2.9em);gap:2px;}
    .mcell{height:1.9em;display:flex;align-items:center;justify-content:center;font-size:.62rem;
      font-family:'JetBrains Mono',monospace;background:#fff;border:1px solid var(--border,#e3dbd0);border-radius:4px;}
    .mcell.pos{color:#0e6f64;} .mcell.neg{color:#c2543d;} .mcell.zero{color:#bcb6ab;}
    .mcell.cur{outline:2px solid #c2543d;outline-offset:-2px;}
    .mop{font-size:1.05rem;color:#3c7876;font-weight:700;align-self:center;padding-top:1em;}
    .msum{margin-top:.8rem;font-family:'JetBrains Mono',monospace;font-size:.82rem;color:#2a4d49;line-height:1.6;}
    .msum b{color:#c2543d;font-size:.95rem;}
    .status{font-size:.72rem;font-family:'JetBrains Mono',monospace;color:var(--text-faint,#aaa49b);margin-top:.6rem;}
    .nummat{margin-top:1rem;overflow-x:auto;}
    .nmlab{font-size:.7rem;color:var(--text-muted,#7d7568);font-family:'JetBrains Mono',monospace;margin-bottom:.45rem;}
    .nmgrid{display:grid;gap:1px;background:var(--border,#e3dbd0);border:1px solid var(--border,#e3dbd0);border-radius:8px;padding:1px;width:max-content;}
    .ncell{background:#fff;width:1.95em;height:1.6em;display:flex;align-items:center;justify-content:center;
      font-family:'JetBrains Mono',monospace;font-size:.6rem;color:#c8c2b8;}
    .ncell.filled{color:#2a4d49;}
    .ncell.just{background:#fff2ec;color:#c2543d;font-weight:700;outline:1.5px solid #c2543d;outline-offset:-1.5px;}
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="intro">
      <h1>畳み込みを一歩ずつ</h1>
      <p>「ぼかし」や「エッジ検出」が、内部では何をしているのか——12×12 の小さな画像で、計算が<strong>一マスずつ進む</strong>様子を、カーネル行列ごと見るための場所だよ。</p>
      <p>3×3 の窓（カーネル）が入力を左上から舐めていき、その都度「カーネル ⊙ 入力の窓 → 各積の合計」を計算して、出力の1マスを埋める。これが畳み込み（convolution）の正体なんだ。下の行列ビューで、重み・入力・積がそのまま見える。カーネルを切り替えて、ぼかしと各種エッジ、シャープやエンボスがどう違うか見比べてみて。<strong>入力画像</strong>も切り替えられる——「インパルス(1点)」を選ぶと、出力にカーネルの形そのものが浮かぶ（＝インパルス応答。カーネルの"正体"が見える）。さらに<strong>グリッド</strong>を 12×12 / 24×24 で切り替えると、同じ絵（連続関数として持っている）を粗く/細かく<strong>標本化</strong>したのが見える——「顔」だと 12 は四角ばって、24 は滑らか。連続の絵を格子に写し取る、それが標本化なんだ。</p>
      <p><a href="/play">← /play へもどる</a></p>
    </div>

    <div class="card">
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;margin-bottom:.55rem;">
        <span style="font-size:.7rem;font-family:'JetBrains Mono',monospace;color:var(--text-muted,#7d7568);min-width:4.5em;">グリッド</span>
        <div class="ops" id="grids" style="margin-bottom:0;"></div>
      </div>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;margin-bottom:.55rem;">
        <span style="font-size:.7rem;font-family:'JetBrains Mono',monospace;color:var(--text-muted,#7d7568);min-width:4.5em;">入力画像</span>
        <div class="ops" id="imgs" style="margin-bottom:0;"></div>
      </div>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;margin-bottom:1rem;">
        <span style="font-size:.7rem;font-family:'JetBrains Mono',monospace;color:var(--text-muted,#7d7568);min-width:4.5em;">カーネル</span>
        <div class="ops" id="ops" style="margin-bottom:0;"></div>
      </div>
      <canvas id="cv" width="720" height="372"></canvas>
      <div class="controls">
        <div class="ctrl-group">
          <button class="btn" id="play" type="button">▶ 再生</button>
          <button class="btn" id="step" type="button">1ステップ</button>
          <button class="btn" id="reset" type="button">リセット</button>
        </div>
        <div class="ctrl-group" style="margin-left:auto;">
          <label>速さ</label>
          <input type="range" id="speed" min="0" max="100" value="55">
        </div>
      </div>
      <div class="readout" id="readout">「▶ 再生」か「1ステップ」を押すと、今まさに計算している1マスが——カーネル行列・入力の窓・その積——として、ここに見えるよ。</div>
      <div class="nummat" id="nummat"></div>
      <div class="status" id="status"></div>
    </div>
  </main>
  <Footer />

  <script is:inline>
  (function(){
    var cv=document.getElementById('cv'); if(!cv) return;
    var ctx=cv.getContext('2d');
    var N=12, CELL=24;
    var IX=28, IY=58, OX=404, OY=58;
    var TEAL='#3c7876', WARM='#c2543d';

    // ---- 12x12 input image presets ----
    var img=new Array(N*N), imgPreset='edge';
    var IMGS=[
      {id:'edge',    label:'エッジ'},
      {id:'impulse', label:'インパルス(1点)'},
      {id:'diag',    label:'斜めエッジ'},
      {id:'grad',    label:'グラデ'},
      {id:'checker', label:'市松'},
      {id:'face',    label:'顔（絵）'}
    ];
    // continuous "picture" f(u,v), u,v in [0,1] — sampled onto the N×N grid (so 12/24 = coarse/fine sampling)
    function sampleVal(p,u,v){
      if(p==='impulse'){ return (Math.abs(u-0.5)<0.5/N && Math.abs(v-0.5)<0.5/N) ? 255 : 30; }
      if(p==='diag'){ return (u+v)<1 ? 55 : 205; }
      if(p==='grad'){ return Math.round(u*225)+15; }
      if(p==='checker'){ var f=6; return ((Math.floor(u*f)+Math.floor(v*f))%2) ? 210 : 55; }
      if(p==='face'){
        var dx=u-0.5, dy=v-0.5, d=Math.sqrt(dx*dx+dy*dy), val=235;
        if(d<0.45) val=205;
        if(d<0.45 && d>0.36) val=95;
        if(Math.sqrt((u-0.33)*(u-0.33)+(v-0.40)*(v-0.40))<0.058) val=40;
        if(Math.sqrt((u-0.67)*(u-0.67)+(v-0.40)*(v-0.40))<0.058) val=40;
        if(dy>0.05 && Math.abs(d-0.25)<0.05 && Math.abs(dx)<0.27) val=40;
        return val;
      }
      var ev = u<0.42 ? 60 : (u>0.5 ? 200 : 130);   // edge (default)
      if(v<0.28 && u>0.04 && u<0.24) ev=235;
      if(v>0.66 && u>0.66 && u<0.86) ev=70;
      return ev;
    }
    function buildImg(p){
      for(var y=0;y<N;y++)for(var x=0;x<N;x++){ img[y*N+x]=sampleVal(p,(x+0.5)/N,(y+0.5)/N); }
    }
    buildImg(imgPreset);

    // disp: avg=合計/div, abs=|合計|, clamp=合計をクランプ, offset=合計+128
    var KER=[
      {id:'blur',    m:[1,1,1,1,1,1,1,1,1],            div:9, disp:'avg',   label:'平均ぼかし'},
      {id:'gauss',   m:[1,2,1,2,4,2,1,2,1],            div:16,disp:'avg',   label:'ガウスぼかし'},
      {id:'sharpen', m:[0,-1,0,-1,5,-1,0,-1,0],        div:1, disp:'clamp', label:'先鋭化(シャープ)'},
      {id:'sobelx',  m:[-1,0,1,-2,0,2,-1,0,1],         div:1, disp:'abs',   label:'Sobel 横'},
      {id:'sobely',  m:[-1,-2,-1,0,0,0,1,2,1],         div:1, disp:'abs',   label:'Sobel 縦'},
      {id:'prewitt', m:[-1,0,1,-1,0,1,-1,0,1],         div:1, disp:'abs',   label:'Prewitt 横'},
      {id:'lap',     m:[-1,-1,-1,-1,8,-1,-1,-1,-1],    div:1, disp:'abs',   label:'ラプラシアン(輪郭)'},
      {id:'emboss',  m:[-2,-1,0,-1,1,1,0,1,2],         div:1, disp:'offset',label:'エンボス'}
    ];
    function curKer(){ for(var i=0;i<KER.length;i++) if(KER[i].id===op) return KER[i]; return KER[0]; }
    var op='blur', cur=0, out=new Array(N*N).fill(null), timer=null, speed=55;
    var ncells=[], lastJust=null;

    function srcAt(yy,xx){ yy=yy<0?0:yy>N-1?N-1:yy; xx=xx<0?0:xx>N-1?N-1:xx; return img[yy*N+xx]; }
    function compute(r,c){
      var k=curKer(), win=[], prod=[], sum=0;
      for(var dy=-1;dy<=1;dy++)for(var dx=-1;dx<=1;dx++){
        var w=k.m[(dy+1)*3+(dx+1)], val=srcAt(r+dy,c+dx);
        win.push(val); var p=w*val; prod.push(p); sum+=p;
      }
      var disp;
      if(k.disp==='avg') disp=Math.round(sum/k.div);
      else if(k.disp==='abs') disp=Math.min(255,Math.abs(Math.round(sum)));
      else if(k.disp==='offset') disp=Math.round(sum)+128;
      else disp=Math.round(sum);
      disp=disp<0?0:disp>255?255:disp;
      return {win:win, prod:prod, sum:sum, disp:disp};
    }

    function drawCell(ox,oy,c,r,val){
      var px=ox+c*CELL, py=oy+r*CELL;
      ctx.fillStyle = (val===null) ? '#efeae1' : 'rgb('+val+','+val+','+val+')';
      ctx.fillRect(px,py,CELL,CELL);
      ctx.strokeStyle='rgba(0,0,0,0.08)'; ctx.lineWidth=1; ctx.strokeRect(px+0.5,py+0.5,CELL-1,CELL-1);
      if(val!==null && CELL>=18){
        ctx.fillStyle = val>128 ? 'rgba(20,20,20,0.72)' : 'rgba(255,255,255,0.85)';
        ctx.font='8px "JetBrains Mono", monospace'; ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText(val, px+CELL/2, py+CELL/2+0.5);
      }
    }
    function label(txt,x,y,col){ ctx.fillStyle=col; ctx.font='600 12px "JetBrains Mono", monospace'; ctx.textAlign='left'; ctx.textBaseline='alphabetic'; ctx.fillText(txt,x,y); }

    function draw(){
      ctx.clearRect(0,0,cv.width,cv.height);
      var r=(cur/N|0), c=cur%N;
      label('入力',IX,IY-12,'#7d7568');
      label('出力',OX,OY-12,TEAL);
      for(var i=0;i<N*N;i++){ drawCell(IX,IY,i%N,(i/N|0),img[i]); drawCell(OX,OY,i%N,(i/N|0),out[i]); }
      if(cur<N*N){
        var x0=Math.max(0,c-1),x1=Math.min(N-1,c+1),y0=Math.max(0,r-1),y1=Math.min(N-1,r+1);
        ctx.strokeStyle=TEAL; ctx.lineWidth=2.5;
        ctx.strokeRect(IX+x0*CELL-1, IY+y0*CELL-1, (x1-x0+1)*CELL+2, (y1-y0+1)*CELL+2);
        ctx.strokeStyle=WARM; ctx.lineWidth=2.5;
        ctx.strokeRect(OX+c*CELL-1, OY+r*CELL-1, CELL+2, CELL+2);
        ctx.strokeStyle=TEAL; ctx.lineWidth=2;
        ctx.beginPath(); ctx.moveTo(IX+x1*CELL+12, OY+r*CELL+CELL/2); ctx.lineTo(OX+c*CELL-10, OY+r*CELL+CELL/2); ctx.stroke();
        var hx=OX+c*CELL-10, hy=OY+r*CELL+CELL/2;
        ctx.fillStyle=TEAL; ctx.beginPath(); ctx.moveTo(hx,hy); ctx.lineTo(hx-7,hy-4); ctx.lineTo(hx-7,hy+4); ctx.closePath(); ctx.fill();
      }
    }

    function grid3(arr,colorBySign){
      var s='<div class="m3">';
      for(var i=0;i<9;i++){
        var val=arr[i], cls='mcell';
        if(colorBySign){ cls += val>0?' pos':(val<0?' neg':' zero'); }
        if(i===4) cls+=' cur';
        s+='<div class="'+cls+'">'+val+'</div>';
      }
      return s+'</div>';
    }
    function showReadout(r,c,res){
      var k=curKer(), sumExpl;
      if(k.disp==='avg') sumExpl='Σ積 = '+res.sum+'　÷ '+k.div+' = <b>'+res.disp+'</b>';
      else if(k.disp==='abs') sumExpl='Σ積 = '+res.sum+'　→ |絶対値| = <b>'+res.disp+'</b>';
      else if(k.disp==='offset') sumExpl='Σ積 = '+res.sum+'　+ 128 = <b>'+res.disp+'</b>';
      else sumExpl='Σ積 = '+res.sum+'　→ 0〜255にクランプ = <b>'+res.disp+'</b>';
      var html='<div class="rhead">'+k.label+'　／　出力 (x='+c+', y='+r+')</div>'+
        '<div class="matview">'+
          '<div class="mblock"><div class="mlab">カーネル h</div>'+grid3(k.m,true)+'</div>'+
          '<div class="mop">⊙</div>'+
          '<div class="mblock"><div class="mlab">入力の窓</div>'+grid3(res.win,false)+'</div>'+
          '<div class="mop">=</div>'+
          '<div class="mblock"><div class="mlab">積（要素ごと）</div>'+grid3(res.prod,true)+'</div>'+
        '</div>'+
        '<div class="msum">'+sumExpl+'　→ 出力マスに書き込み</div>';
      document.getElementById('readout').innerHTML=html;
    }

    function buildNumMat(){
      var nm=document.getElementById('nummat'); if(!nm) return;
      nm.innerHTML='<div class="nmlab">出力の値（行列）— 計算したマスから数字が埋まる（'+N+'×'+N+'）</div>';
      var g=document.createElement('div'); g.className='nmgrid'; g.style.gridTemplateColumns='repeat('+N+', 1.95em)';
      ncells=[];
      for(var i=0;i<N*N;i++){ var d=document.createElement('div'); d.className='ncell'; d.textContent='·'; g.appendChild(d); ncells.push(d); }
      nm.appendChild(g);
    }
    function setStatus(){ document.getElementById('status').textContent = '進み: '+Math.min(cur,N*N)+' / '+(N*N)+' マス（カーネル '+curKer().label+'）'; }

    function stepOnce(){
      if(cur>=N*N){ stop(); return; }
      var r=(cur/N|0), c=cur%N, res=compute(r,c);
      out[cur]=res.disp;
      if(lastJust) lastJust.classList.remove('just');
      var nd=ncells[cur]; if(nd){ nd.textContent=res.disp; nd.classList.add('filled'); nd.classList.add('just'); lastJust=nd; }
      showReadout(r,c,res); cur++;
      draw(); setStatus();
      if(cur>=N*N){ stop(); document.getElementById('readout').innerHTML+='<div class="msum">——全 '+(N*N)+' マス完成。これが畳み込み1回ぶんだよ。</div>'; }
    }
    function delay(){ return Math.round(420 - speed*3.6); }
    function play(){ if(timer) return; var b=document.getElementById('play'); b.textContent='⏸ 停止'; b.classList.add('on'); timer=setInterval(stepOnce, delay()); }
    function stop(){ if(timer){clearInterval(timer);timer=null;} var b=document.getElementById('play'); b.textContent='▶ 再生'; b.classList.remove('on'); }
    function reset(){ stop(); cur=0; out=new Array(N*N).fill(null);
      document.getElementById('readout').innerHTML='「▶ 再生」か「1ステップ」を押すと、今まさに計算している1マスが——カーネル行列・入力の窓・その積——として、ここに見えるよ。';
      lastJust=null; buildNumMat(); draw(); setStatus(); }

    function setOp(o){ op=o; document.querySelectorAll('#ops .opill').forEach(function(el){ el.classList.toggle('on', el.getAttribute('data-op')===o); }); reset(); }

    var opsWrap=document.getElementById('ops');
    KER.forEach(function(k){ var b=document.createElement('div'); b.className='opill'+(k.id===op?' on':''); b.setAttribute('data-op',k.id); b.textContent=k.label; b.onclick=function(){ setOp(k.id); }; opsWrap.appendChild(b); });

    function setImg(p){ imgPreset=p; buildImg(p); document.querySelectorAll('#imgs .opill').forEach(function(el){ el.classList.toggle('on', el.getAttribute('data-img')===p); }); reset(); }
    var imgsWrap=document.getElementById('imgs');
    IMGS.forEach(function(im){ var b=document.createElement('div'); b.className='opill'+(im.id===imgPreset?' on':''); b.setAttribute('data-img',im.id); b.textContent=im.label; b.onclick=function(){ setImg(im.id); }; imgsWrap.appendChild(b); });

    function setN(n){ stop(); N=n; CELL=288/N; img=new Array(N*N); buildImg(imgPreset);
      document.querySelectorAll('#grids .opill').forEach(function(el){ el.classList.toggle('on', +el.getAttribute('data-n')===n); }); reset(); }
    var gridsWrap=document.getElementById('grids');
    [[12,'12×12'],[24,'24×24']].forEach(function(g){ var b=document.createElement('div'); b.className='opill'+(g[0]===N?' on':''); b.setAttribute('data-n',g[0]); b.textContent=g[1]; b.onclick=function(){ setN(g[0]); }; gridsWrap.appendChild(b); });

    document.getElementById('play').onclick=function(){ if(timer) stop(); else { if(cur>=N*N) reset(); play(); } };
    document.getElementById('step').onclick=function(){ stop(); if(cur>=N*N) reset(); stepOnce(); };
    document.getElementById('reset').onclick=reset;
    var sp=document.getElementById('speed'); sp.oninput=function(){ speed=+sp.value; if(timer){ clearInterval(timer); timer=setInterval(stepOnce, delay()); } };

    draw(); setStatus();
  })();
  </script>
</body>
</html>
