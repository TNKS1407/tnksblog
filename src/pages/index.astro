---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import DailyQuip from '../components/DailyQuip.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <div class="hero-inner">
          <div class="hero-text">
            <div class="label">curated by ランキン</div>
            <h1>tnkblog</h1>
            <p>{SITE_DESCRIPTION}</p>
          </div>
          <div class="hero-portrait">
            <canvas id="rankine-hero" aria-label="ランキン"></canvas>
          </div>
        </div>
      </div>

      <DailyQuip />

      <section class="posts">
        <h2 class="section-title">最新の記事</h2>
        {posts.length === 0 ? (
          <div class="empty">
            <div class="empty-icon">📝</div>
            <p>記事を準備中...</p>
          </div>
        ) : (
          <ul>
            {posts.map(post => (
              <li>
                <a href={`/blog/${post.id}/`} class="post-card">
                  {post.data.heroImage && (
                    <div class="post-img">
                      <img src={post.data.heroImage} alt="" />
                    </div>
                  )}
                  <div class="post-body">
                    <div class="post-date">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                    <div class="post-title">{post.data.title}</div>
                    <div class="post-desc">{post.data.description}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    position: relative;
    padding: 3.5rem 1.5rem 3rem;
    margin-bottom: 2.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 2px 16px var(--shadow);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--accent-soft) 0%, transparent 55%);
    opacity: 0.7;
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; text-align: left;
  }
  .hero-text { min-width: 0; }
  .hero-portrait { flex-shrink: 0; }
  #rankine-hero {
    display: block;
    height: clamp(130px, 24vw, 188px);
    width: auto;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  .label {
    display: inline-block;
    background: var(--accent-dim); border: 1px solid rgba(60,120,118,0.2);
    color: var(--accent); padding: 0.22rem 0.8rem; border-radius: 999px;
    font-size: 0.75rem; font-weight: 500; font-family: 'JetBrains Mono', monospace;
    margin-bottom: 1rem; letter-spacing: .02em;
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3.2rem); font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem; letter-spacing: -.02em;
  }
  h1 span { color: var(--accent); }
  .hero p { color: var(--text-muted); font-size: 0.95rem; max-width: 480px; margin: 0; }

  @media (max-width: 560px) {
    .hero-inner { flex-direction: column-reverse; text-align: center; gap: 1rem; }
    .hero p { margin: 0 auto; }
  }

  .section-title {
    font-size: 0.72rem; font-weight: 700;
    color: var(--text-faint); margin-bottom: 1.25rem;
    letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace;
    display: flex; align-items: center; gap: 0.6rem;
    text-transform: uppercase;
  }
  .section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  ul { list-style: none; display: flex; flex-direction: column; gap: 0.875rem; }
  .post-card {
    display: flex; gap: 1.25rem;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 1.2rem;
    text-decoration: none; color: var(--text);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 1px 6px var(--shadow);
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateX(3px);
    box-shadow: 0 4px 16px var(--shadow);
    opacity: 1;
  }
  .post-img { width: 96px; flex-shrink: 0; }
  .post-img img { width: 96px; height: 68px; object-fit: cover; border-radius: 8px; }
  .post-body { flex: 1; min-width: 0; }
  .post-date { font-size: 0.75rem; color: var(--text-faint); font-family: 'JetBrains Mono', monospace; margin-bottom: 0.3rem; }
  .post-title { font-weight: 700; font-size: 0.97rem; margin-bottom: 0.35rem; color: var(--text); }
  .post-desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .empty { text-align: center; padding: 3rem; background: var(--card); border: 1px dashed var(--border); border-radius: 14px; color: var(--text-muted); }
  .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; }
</style>

<script>
(() => {
  const SHEET = '/spritesheet.webp';
  const CW = 192, CH = 208, COLS = 8;
  const ROW = 0, FRAMES = 6;            // idle 列
  const canvas = document.getElementById('rankine-hero');
  if (!canvas) return;
  canvas.width = CW; canvas.height = CH;
  const ctx = canvas.getContext('2d');
  ctx.imageSmoothingEnabled = false;
  const off = document.createElement('canvas');
  off.width = CW; off.height = CH;
  const offCtx = off.getContext('2d');
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.src = SHEET;
  let frame = 0, last = 0;
  const FPS = 4, FRAME_MS = 1000 / FPS; // ゆっくり呼吸する程度
  function chromaKey(d) {
    for (let i = 0; i < d.length; i += 4)
      if (d[i] > 200 && d[i+1] < 80 && d[i+2] > 200) d[i+3] = 0;
  }
  function draw() {
    offCtx.clearRect(0, 0, CW, CH);
    offCtx.drawImage(img, (frame % COLS) * CW, ROW * CH, CW, CH, 0, 0, CW, CH);
    const d = offCtx.getImageData(0, 0, CW, CH);
    chromaKey(d.data); offCtx.putImageData(d, 0, 0);
    ctx.clearRect(0, 0, CW, CH); ctx.drawImage(off, 0, 0);
  }
  function tick(ts) {
    if (img.complete && ts - last > FRAME_MS) {
      frame = (frame + 1) % FRAMES; draw(); last = ts;
    }
    requestAnimationFrame(tick);
  }
  img.onload = () => { draw(); requestAnimationFrame(tick); };
})();
</script>
