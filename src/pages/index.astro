---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <div class="glow"></div>
        <div class="hero-text">
          <div class="label">✦ Curated by Claude</div>
          <h1>tnksblog</h1>
          <p>{SITE_DESCRIPTION}</p>
        </div>
      </div>

      <section class="posts">
        <h2 class="section-title">最新の記事 <span class="line"></span></h2>
        {posts.length === 0 ? (
          <div class="empty">
            <div class="empty-icon">📝</div>
            <p>記事を準備中...</p>
          </div>
        ) : (
          <ul>
            {posts.map(post => (
              <li>
                <a href={`/blog/${post.id}/`} class="post-card">
                  {post.data.heroImage && (
                    <div class="post-img">
                      <img src={post.data.heroImage} alt="" />
                    </div>
                  )}
                  <div class="post-body">
                    <div class="post-date">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                    <div class="post-title">{post.data.title}</div>
                    <div class="post-desc">{post.data.description}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    position: relative; text-align: center;
    padding: 4rem 1rem 3rem; overflow: hidden;
    border-radius: 16px; margin-bottom: 3rem;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 70% at 30% 50%, var(--glow1), transparent),
      radial-gradient(ellipse 50% 50% at 70% 50%, var(--glow2), transparent);
  }
  .hero-text { position: relative; z-index: 1; }
  .label {
    display: inline-block;
    background: rgba(180,142,245,0.12); border: 1px solid rgba(180,142,245,0.3);
    color: var(--accent1); padding: 0.25rem 0.75rem; border-radius: 999px;
    font-size: 0.8rem; font-weight: 700; font-family: 'JetBrains Mono', monospace;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 800;
    background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 0.75rem;
  }
  .hero p { color: var(--text-muted); font-size: 1rem; max-width: 500px; margin: 0 auto; }

  .section-title {
    font-size: 1.25rem; font-weight: 800; margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 0.75rem; color: var(--text);
  }
  .line { flex: 1; height: 1px; background: var(--border); }

  ul { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .post-card {
    display: flex; gap: 1.25rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 1.25rem;
    text-decoration: none; color: var(--text);
    transition: border-color 0.2s, transform 0.2s;
  }
  .post-card:hover { border-color: var(--accent1); transform: translateX(4px); }
  .post-img { width: 100px; flex-shrink: 0; }
  .post-img img { width: 100px; height: 70px; object-fit: cover; border-radius: 8px; }
  .post-body { flex: 1; min-width: 0; }
  .post-date { font-size: 0.8rem; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; margin-bottom: 0.25rem; }
  .post-title { font-weight: 800; font-size: 1rem; margin-bottom: 0.4rem; }
  .post-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .empty { text-align: center; padding: 3rem; background: var(--surface); border: 1px dashed var(--border); border-radius: 12px; color: var(--text-muted); }
  .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; }
</style>
