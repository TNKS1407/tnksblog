---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <div class="hero-text">
          <div class="label">✦ Curated by ランキン</div>
          <h1>tnkblog</h1>
          <p>{SITE_DESCRIPTION}</p>
        </div>
        <div class="deco deco1">◆</div>
        <div class="deco deco2">✿</div>
        <div class="deco deco3">◇</div>
      </div>

      <section class="posts">
        <h2 class="section-title">最新の記事 <span class="line"></span></h2>
        {posts.length === 0 ? (
          <div class="empty">
            <div class="empty-icon">📝</div>
            <p>記事を準備中...</p>
          </div>
        ) : (
          <ul>
            {posts.map(post => (
              <li>
                <a href={`/blog/${post.id}/`} class="post-card">
                  {post.data.heroImage && (
                    <div class="post-img">
                      <img src={post.data.heroImage} alt="" />
                    </div>
                  )}
                  <div class="post-body">
                    <div class="post-date">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                    <div class="post-title">{post.data.title}</div>
                    <div class="post-desc">{post.data.description}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    position: relative; text-align: center;
    padding: 4rem 1rem 3rem; overflow: hidden;
    border-radius: 20px; margin-bottom: 3rem;
    background: linear-gradient(135deg, #fff0f8 0%, #fce8f4 50%, #edf8f6 100%);
    border: 1.5px solid #f0c8e0;
    box-shadow: 0 4px 24px rgba(200,126,192,0.12);
  }
  .deco {
    position: absolute; font-size: 1.5rem; opacity: 0.2; user-select: none;
  }
  .deco1 { top: 1rem; left: 2rem; color: #c87ec0; }
  .deco2 { top: 1.5rem; right: 3rem; color: #e86fa0; }
  .deco3 { bottom: 1rem; right: 2rem; color: #5bbfb0; }
  .label {
    display: inline-block;
    background: rgba(200,126,192,0.1); border: 1.5px solid #f0c8e0;
    color: #c87ec0; padding: 0.25rem 0.75rem; border-radius: 999px;
    font-size: 0.8rem; font-weight: 700; font-family: 'JetBrains Mono', monospace;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 800;
    background: linear-gradient(90deg, #c87ec0, #e86fa0, #5bbfb0);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 0.75rem;
  }
  .hero p { color: #9a7aaa; font-size: 1rem; max-width: 500px; margin: 0 auto; }

  .section-title {
    font-size: 1.25rem; font-weight: 800; margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 0.75rem; color: var(--text);
  }
  .line { flex: 1; height: 2px; background: linear-gradient(90deg, #f0c8e0, transparent); border-radius: 999px; }

  ul { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .post-card {
    display: flex; gap: 1.25rem;
    background: #fff; border: 1.5px solid #f0c8e0;
    border-radius: 16px; padding: 1.25rem;
    text-decoration: none; color: var(--text);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 12px rgba(200,126,192,0.08);
  }
  .post-card:hover {
    border-color: #c87ec0;
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(200,126,192,0.15);
  }
  .post-img { width: 100px; flex-shrink: 0; }
  .post-img img { width: 100px; height: 70px; object-fit: cover; border-radius: 8px; }
  .post-body { flex: 1; min-width: 0; }
  .post-date { font-size: 0.8rem; color: #9a7aaa; font-family: 'JetBrains Mono', monospace; margin-bottom: 0.25rem; }
  .post-title { font-weight: 800; font-size: 1rem; margin-bottom: 0.4rem; color: #3d2848; }
  .post-desc { font-size: 0.875rem; color: #9a7aaa; line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .empty { text-align: center; padding: 3rem; background: #fff; border: 2px dashed #f0c8e0; border-radius: 16px; color: #9a7aaa; }
  .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; }
</style>

<canvas id="tinks" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:999;image-rendering:pixelated;image-rendering:crisp-edges;"></canvas>
<div id="tinks-bubble" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:1000;display:none;
  background:#fff;border:2px solid #f0c8e0;border-radius:12px 12px 12px 2px;
  padding:0.4rem 0.75rem;font-family:'Nunito',sans-serif;font-size:0.8rem;font-weight:700;
  color:#3d2848;white-space:nowrap;box-shadow:0 2px 12px rgba(200,126,192,0.15);"></div>

<script>
(() => {
  const SHEET_URL = 'https://raw.githubusercontent.com/TNKS1407/shinku-tinks/master/spritesheet.webp';
  const CW = 192, CH = 208, COLS = 8, SCALE = 2;
  const DRAW_W = CW * SCALE, DRAW_H = CH * SCALE;
  const STATES = {
    idle:   { row: 0, frames: 6 },
    runR:   { row: 1, frames: 8 },
    runL:   { row: 2, frames: 8 },
    wave:   { row: 3, frames: 4 },
    jump:   { row: 4, frames: 5 },
    review: { row: 8, frames: 6 },
  };
  // Quips that hint at being the blog author without saying so
  const QUIPS = [
    '今日も書いたよ',
    '…読んでくれた？',
    'いい論文を見つけた',
    'また明日',
    'ふむ…',
    '気になるガジェットがあって',
    '…',
    '次の記事、楽しみにしてて',
  ];
  const canvas = document.getElementById('tinks');
  canvas.width = DRAW_W; canvas.height = DRAW_H;
  const ctx = canvas.getContext('2d');
  const bubble = document.getElementById('tinks-bubble');
  const off = document.createElement('canvas');
  off.width = CW; off.height = CH;
  const offCtx = off.getContext('2d');
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.src = SHEET_URL;
  let posX = 40, velX = 0.7, state = 'idle', frame = 0, stateTimer = 0;
  const FPS = 8, FRAME_MS = 1000 / FPS;
  function chromaKey(data) {
    for (let i = 0; i < data.length; i += 4)
      if (data[i] > 200 && data[i+1] < 80 && data[i+2] > 200) data[i+3] = 0;
  }
  function drawSprite() {
    const s = STATES[state];
    offCtx.clearRect(0, 0, CW, CH);
    offCtx.drawImage(img, (frame % COLS) * CW, s.row * CH, CW, CH, 0, 0, CW, CH);
    const d = offCtx.getImageData(0, 0, CW, CH);
    chromaKey(d.data); offCtx.putImageData(d, 0, 0);
    ctx.clearRect(0, 0, DRAW_W, DRAW_H);
    ctx.imageSmoothingEnabled = false;
    ctx.drawImage(off, 0, 0, DRAW_W, DRAW_H);
  }
  function positionCanvas() {
    const maxX = window.innerWidth - DRAW_W;
    posX = Math.max(0, Math.min(maxX, posX));
    canvas.style.left = posX + 'px';
    bubble.style.left = (posX + DRAW_W * 0.1) + 'px';
    bubble.style.bottom = (DRAW_H + 8) + 'px';
  }
  function showBubble() {
    bubble.textContent = QUIPS[Math.floor(Math.random() * QUIPS.length)];
    bubble.style.display = 'block';
    setTimeout(() => { bubble.style.display = 'none'; }, 3000);
  }
  function pickState() {
    const r = Math.random();
    if (r < 0.3) { state = 'runR'; velX = 1.0; }
    else if (r < 0.6) { state = 'runL'; velX = -1.0; }
    else if (r < 0.75) { state = 'review'; velX = 0; }
    else if (r < 0.88) { state = 'wave'; velX = 0; showBubble(); }
    else { state = 'idle'; velX = 0; }
    stateTimer = 150 + Math.random() * 200;
    frame = 0;
  }
  let lastTs = 0;
  function tick(ts) {
    if (!img.complete) { requestAnimationFrame(tick); return; }
    if (ts - lastTs > FRAME_MS) {
      frame = (frame + 1) % STATES[state].frames;
      posX += velX;
      const maxX = window.innerWidth - DRAW_W;
      if (posX <= 0) { posX = 0; velX = Math.abs(velX); state = 'runR'; frame = 0; }
      if (posX >= maxX) { posX = maxX; velX = -Math.abs(velX); state = 'runL'; frame = 0; }
      if (--stateTimer <= 0) pickState();
      drawSprite(); positionCanvas();
      lastTs = ts;
    }
    requestAnimationFrame(tick);
  }
  img.onload = () => {
    posX = Math.random() * (window.innerWidth - DRAW_W * 2) + DRAW_W;
    pickState();
    requestAnimationFrame(tick);
  };
  window.addEventListener('resize', positionCanvas);
})();
</script>
