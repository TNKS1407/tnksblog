---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <div class="hero-inner">
          <div class="label">curated by ランキン</div>
          <h1>tnkblog</h1>
          <p>{SITE_DESCRIPTION}</p>
        </div>
      </div>

      <section class="posts">
        <h2 class="section-title">最新の記事</h2>
        {posts.length === 0 ? (
          <div class="empty">
            <div class="empty-icon">📝</div>
            <p>記事を準備中...</p>
          </div>
        ) : (
          <ul>
            {posts.map(post => (
              <li>
                <a href={`/blog/${post.id}/`} class="post-card">
                  {post.data.heroImage && (
                    <div class="post-img">
                      <img src={post.data.heroImage} alt="" />
                    </div>
                  )}
                  <div class="post-body">
                    <div class="post-date">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                    <div class="post-title">{post.data.title}</div>
                    <div class="post-desc">{post.data.description}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    position: relative;
    padding: 3.5rem 1.5rem 3rem;
    margin-bottom: 2.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 2px 16px var(--shadow);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--accent-soft) 0%, transparent 55%);
    opacity: 0.7;
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; text-align: center; }
  .label {
    display: inline-block;
    background: var(--accent-dim); border: 1px solid rgba(60,120,118,0.2);
    color: var(--accent); padding: 0.22rem 0.8rem; border-radius: 999px;
    font-size: 0.75rem; font-weight: 500; font-family: 'JetBrains Mono', monospace;
    margin-bottom: 1rem; letter-spacing: .02em;
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3.2rem); font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem; letter-spacing: -.02em;
  }
  h1 span { color: var(--accent); }
  .hero p { color: var(--text-muted); font-size: 0.95rem; max-width: 480px; margin: 0 auto; }

  .section-title {
    font-size: 0.72rem; font-weight: 700;
    color: var(--text-faint); margin-bottom: 1.25rem;
    letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace;
    display: flex; align-items: center; gap: 0.6rem;
    text-transform: uppercase;
  }
  .section-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  ul { list-style: none; display: flex; flex-direction: column; gap: 0.875rem; }
  .post-card {
    display: flex; gap: 1.25rem;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 1.2rem;
    text-decoration: none; color: var(--text);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 1px 6px var(--shadow);
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateX(3px);
    box-shadow: 0 4px 16px var(--shadow);
    opacity: 1;
  }
  .post-img { width: 96px; flex-shrink: 0; }
  .post-img img { width: 96px; height: 68px; object-fit: cover; border-radius: 8px; }
  .post-body { flex: 1; min-width: 0; }
  .post-date { font-size: 0.75rem; color: var(--text-faint); font-family: 'JetBrains Mono', monospace; margin-bottom: 0.3rem; }
  .post-title { font-weight: 700; font-size: 0.97rem; margin-bottom: 0.35rem; color: var(--text); }
  .post-desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .empty { text-align: center; padding: 3rem; background: var(--card); border: 1px dashed var(--border); border-radius: 14px; color: var(--text-muted); }
  .empty-icon { font-size: 2rem; margin-bottom: 0.5rem; }
</style>

<canvas id="tinks" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:999;image-rendering:pixelated;image-rendering:crisp-edges;"></canvas>
<div id="tinks-bubble" style="position:fixed;bottom:0;left:0;pointer-events:none;z-index:1000;display:none;
  background:#fff;border:1.5px solid #c8bfb2;border-radius:12px 12px 12px 2px;
  padding:0.4rem 0.75rem;font-family:'Zen Kaku Gothic New',sans-serif;font-size:0.78rem;font-weight:500;
  color:#1d1b17;white-space:nowrap;box-shadow:0 2px 10px rgba(29,27,23,0.1);"></div>

<script>
(() => {
  const SHEET_URL = '/spritesheet.webp';
  const CW = 192, CH = 208, COLS = 8;
  const getScale = () => window.innerWidth < 480 ? 0.65 : window.innerWidth < 768 ? 0.9 : 1.25;
  let SCALE = getScale();
  let DRAW_W = CW * SCALE, DRAW_H = CH * SCALE;
  const STATES = {
    idle:   { row: 0, frames: 6 },
    runR:   { row: 1, frames: 8 },
    runL:   { row: 2, frames: 8 },
    wave:   { row: 3, frames: 4 },
    jump:   { row: 4, frames: 5 },
    review: { row: 8, frames: 6 },
  };
  const BLOG_QUIPS = [
    '今日も書いたよ', '…読んでくれた？', 'いい論文を見つけた',
    'また明日', 'ふむ…', '気になるものがあって',
    '…', '次の記事、楽しみにしてて', 'ゆっくり読んでいってね',
    'この記事、結構好き', '難しいところは飛ばしていいよ',
  ];
  const PET_QUIPS = ['くすぐったいよ', 'なでなでしすぎ…', 'もう…', 'えへへ', '止まらないの？'];

  function randQ(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  const canvas = document.getElementById('tinks');
  function resizeCanvas() {
    SCALE = getScale(); DRAW_W = CW * SCALE; DRAW_H = CH * SCALE;
    canvas.width = DRAW_W; canvas.height = DRAW_H;
  }
  resizeCanvas();
  const ctx = canvas.getContext('2d');
  const bubble = document.getElementById('tinks-bubble');

  /* footprints */
  const footCanvas = document.createElement('canvas');
  footCanvas.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:997;';
  document.body.appendChild(footCanvas);
  const footCtx = footCanvas.getContext('2d');
  const footResize = () => { footCanvas.width = window.innerWidth; footCanvas.height = window.innerHeight; };
  footResize(); window.addEventListener('resize', footResize);
  const footprints = []; let footStep = 0;
  function addFootprint() {
    if (state !== 'runR' && state !== 'runL') return;
    if (++footStep % 18 !== 0) return;
    footprints.push({ x: posX + DRAW_W * 0.45 + (state === 'runR' ? 1 : -1) * DRAW_W * 0.18,
      y: window.innerHeight - 6, life: 1.0 });
    if (footprints.length > 30) footprints.shift();
  }
  function drawFootprints() {
    footCtx.clearRect(0, 0, footCanvas.width, footCanvas.height);
    for (const f of footprints) {
      f.life -= 0.012; if (f.life <= 0) continue;
      footCtx.save(); footCtx.globalAlpha = f.life * 0.4; footCtx.fillStyle = '#3c7876';
      footCtx.beginPath(); footCtx.ellipse(f.x, f.y, 4, 2.5, 0.3, 0, Math.PI * 2); footCtx.fill();
      footCtx.restore();
    }
    footprints.splice(0, footprints.filter(f => f.life <= 0).length);
  }

  const off = document.createElement('canvas');
  off.width = CW; off.height = CH;
  const offCtx = off.getContext('2d');
  const img = new Image(); img.crossOrigin = 'anonymous'; img.src = SHEET_URL;
  let posX = 40, velX = 0.7, state = 'idle', frame = 0, stateTimer = 0;
  const FPS = 8, FRAME_MS = 1000 / FPS;
  let petCount = 0, petTimer = null;

  function chromaKey(data) {
    for (let i = 0; i < data.length; i += 4)
      if (data[i] > 200 && data[i+1] < 80 && data[i+2] > 200) data[i+3] = 0;
  }
  function drawSprite() {
    const s = STATES[state];
    offCtx.clearRect(0, 0, CW, CH);
    offCtx.drawImage(img, (frame % COLS) * CW, s.row * CH, CW, CH, 0, 0, CW, CH);
    const d = offCtx.getImageData(0, 0, CW, CH); chromaKey(d.data); offCtx.putImageData(d, 0, 0);
    ctx.clearRect(0, 0, DRAW_W, DRAW_H); ctx.imageSmoothingEnabled = false;
    ctx.drawImage(off, 0, 0, DRAW_W, DRAW_H);
  }
  function positionCanvas() {
    const maxX = window.innerWidth - DRAW_W;
    posX = Math.max(0, Math.min(maxX, posX));
    canvas.style.left = posX + 'px';
    bubble.style.left = (posX + DRAW_W * 0.1) + 'px';
    bubble.style.bottom = (DRAW_H + 8) + 'px';
  }
  function showBubble(text, dur = 3000) {
    bubble.textContent = text; bubble.style.display = 'block';
    clearTimeout(bubble._t); bubble._t = setTimeout(() => { bubble.style.display = 'none'; }, dur);
  }
  function pickState() {
    const r = Math.random();
    /* blog: review pose more frequent */
    if (r < 0.28) { state = 'runR'; velX = 1.0; }
    else if (r < 0.56) { state = 'runL'; velX = -1.0; }
    else if (r < 0.78) { state = 'review'; velX = 0; }
    else if (r < 0.90) { state = 'wave'; velX = 0; showBubble(randQ(BLOG_QUIPS)); }
    else { state = 'idle'; velX = 0; }
    stateTimer = 150 + Math.random() * 200; frame = 0;
  }
  let lastTs = 0;
  function tick(ts) {
    if (!img.complete) { requestAnimationFrame(tick); return; }
    if (ts - lastTs > FRAME_MS) {
      frame = (frame + 1) % STATES[state].frames;
      posX += velX;
      const maxX = window.innerWidth - DRAW_W;
      if (posX <= 0) { posX = 0; velX = Math.abs(velX); state = 'runR'; frame = 0; }
      if (posX >= maxX) { posX = maxX; velX = -Math.abs(velX); state = 'runL'; frame = 0; }
      if (--stateTimer <= 0) pickState();
      addFootprint(); drawSprite(); drawFootprints(); positionCanvas(); lastTs = ts;
    }
    requestAnimationFrame(tick);
  }
  img.onload = () => {
    posX = Math.random() * (window.innerWidth - DRAW_W * 2) + DRAW_W;
    pickState(); requestAnimationFrame(tick);
  };
  window.addEventListener('resize', () => { resizeCanvas(); positionCanvas(); });

  /* pet counter */
  canvas.addEventListener('click', e => {
    e.stopPropagation(); petCount++;
    clearTimeout(petTimer); petTimer = setTimeout(() => { petCount = 0; }, 1200);
    if (petCount >= 5) { state='jump'; velX=0; frame=0; stateTimer=80; showBubble(randQ(PET_QUIPS), 3200); petCount=0; }
    else { state='wave'; velX=0; frame=0; stateTimer=50; showBubble(randQ(PET_QUIPS)); }
  });

  document.addEventListener('click', e => {
    if (e.target === canvas) return;
    state = 'wave'; velX = 0; frame = 0; stateTimer = 60; showBubble(randQ(BLOG_QUIPS));
  });
  document.addEventListener('mousemove', e => {
    const cx = posX + DRAW_W/2, cy = window.innerHeight - DRAW_H/2;
    const dist = Math.hypot(e.clientX - cx, e.clientY - cy);
    if (dist < DRAW_W*0.9 && state !== 'wave' && state !== 'jump') {
      const dir = cx < e.clientX ? 'runL' : 'runR';
      if (state !== dir) { state = dir; velX = dir === 'runR' ? 2.5 : -2.5; frame = 0; stateTimer = 80; }
    } else if (dist < DRAW_W*1.8 && state !== 'wave' && state !== 'jump') {
      state = 'idle'; velX = 0; stateTimer = 40;
    }
  });
})();
</script>
