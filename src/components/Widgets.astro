---
/*
 * Widgets — 記事に埋め込むインタラクティブ部品のマウンタ。
 * 記事側には <div data-widget="名前"></div> を置くだけ。
 * このコンポーネントを全記事レイアウトに 1 つ入れておけば、
 * ページ内の data-widget を探して対応する部品を組み立てる。
 */
---

<style is:global>
  .tw {
    margin: 2rem 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    box-shadow: 0 1px 6px var(--shadow);
  }
  .tw-title {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em;
    color: var(--accent); font-family: 'JetBrains Mono', monospace;
    margin-bottom: 0.9rem; text-transform: uppercase;
  }
  .tw-stage { display: flex; justify-content: center; }
  .tw canvas { width: 100%; max-width: 340px; height: auto; touch-action: none; }
  .tw-wide canvas { max-width: 540px; }
  .tw-controls {
    margin-top: 1rem; display: flex; flex-direction: column; gap: 0.75rem;
  }
  .tw-row { display: flex; align-items: center; gap: 0.75rem; }
  .tw-row label {
    font-size: 0.78rem; color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace; white-space: nowrap;
  }
  .tw input[type=range] {
    flex: 1; accent-color: var(--accent); height: 4px;
  }
  .tw-readout {
    font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;
    color: var(--text); text-align: center; line-height: 1.7;
  }
  .tw-readout b { color: var(--accent); font-weight: 600; }
  .tw-btns { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
  .tw-btn {
    font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
    background: var(--accent-dim); color: var(--accent);
    border: 1px solid rgba(60,120,118,0.25); border-radius: 8px;
    padding: 0.4rem 0.85rem; cursor: pointer; transition: background 0.15s;
  }
  .tw-btn:hover { background: var(--accent-soft); }
  .tw-btn.ghost { background: transparent; color: var(--text-muted); border-color: var(--border); }
</style>

<script>
  // ---- 複素回転 widget ----
  function mountComplexRotation(root: HTMLElement) {
    root.classList.add('tw');
    root.innerHTML = `
      <div class="tw-title">複素平面で回す</div>
      <div class="tw-stage"><canvas width="680" height="680"></canvas></div>
      <div class="tw-controls">
        <div class="tw-row">
          <label>θ</label>
          <input type="range" min="0" max="360" step="1" value="30" />
        </div>
        <div class="tw-readout">
          z = e<sup>jθ</sup> = <b class="re">0.87</b> + <b class="im">0.50</b> j
          <br /><span class="deg">θ = 30°</span>
        </div>
        <div class="tw-btns">
          <button class="tw-btn mul">× j（90°回す）</button>
          <button class="tw-btn ghost reset">リセット</button>
        </div>
      </div>`;

    const canvas = root.querySelector('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const slider = root.querySelector('input[type=range]') as HTMLInputElement;
    const reEl = root.querySelector('.re') as HTMLElement;
    const imEl = root.querySelector('.im') as HTMLElement;
    const degEl = root.querySelector('.deg') as HTMLElement;
    const mulBtn = root.querySelector('.mul') as HTMLElement;
    const resetBtn = root.querySelector('.reset') as HTMLElement;

    const W = canvas.width, H = canvas.height;
    const cx = W / 2, cy = H / 2;
    const R = W * 0.36;                 // 単位円の半径(px)

    let theta = 30;                     // 表示中の角度(deg)
    let target = 30;                    // 補間先

    const css = (v: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(v).trim();

    function draw() {
      const accent = css('--accent') || '#3c7876';
      const border = css('--border') || '#e3dbd0';
      const faint = css('--text-faint') || '#aaa49b';
      const text = css('--text') || '#1d1b17';
      ctx.clearRect(0, 0, W, H);

      // 軸
      ctx.strokeStyle = border; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(20, cy); ctx.lineTo(W - 20, cy);
      ctx.moveTo(cx, 20); ctx.lineTo(cx, H - 20); ctx.stroke();

      // 単位円
      ctx.strokeStyle = faint; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI * 2); ctx.stroke();

      // 軸ラベル 1, j, -1, -j
      ctx.fillStyle = faint; ctx.font = '500 26px "JetBrains Mono", monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('1', cx + R + 22, cy + 16);
      ctx.fillText('-1', cx - R - 24, cy + 16);
      ctx.fillText('j', cx - 16, cy - R - 20);
      ctx.fillText('-j', cx - 18, cy + R + 22);

      const rad = theta * Math.PI / 180;
      const px = cx + R * Math.cos(rad);
      const py = cy - R * Math.sin(rad);

      // 投影線(実部・虚部)
      ctx.strokeStyle = accent; ctx.lineWidth = 1.5; ctx.setLineDash([5, 5]);
      ctx.beginPath(); ctx.moveTo(px, py); ctx.lineTo(px, cy); ctx.stroke(); // →実軸
      ctx.beginPath(); ctx.moveTo(px, py); ctx.lineTo(cx, py); ctx.stroke(); // →虚軸
      ctx.setLineDash([]);

      // 角度の弧（canvasのyは下向きなので -rad 側へ描く）
      ctx.strokeStyle = accent; ctx.globalAlpha = 0.4; ctx.lineWidth = 3;
      ctx.beginPath(); ctx.arc(cx, cy, R * 0.28, 0, -rad, theta > 0); ctx.stroke();
      ctx.globalAlpha = 1;

      // ベクトル
      ctx.strokeStyle = accent; ctx.lineWidth = 4;
      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(px, py); ctx.stroke();

      // 点
      ctx.fillStyle = accent;
      ctx.beginPath(); ctx.arc(px, py, 9, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#fff';
      ctx.beginPath(); ctx.arc(px, py, 3.5, 0, Math.PI * 2); ctx.fill();
    }

    function updateReadout() {
      const rad = theta * Math.PI / 180;
      const re = Math.cos(rad), im = Math.sin(rad);
      reEl.textContent = re.toFixed(2);
      imEl.textContent = (im >= 0 ? '' : '') + im.toFixed(2);
      degEl.textContent = `θ = ${Math.round(theta)}°`;
    }

    let raf = 0;
    function animate() {
      const diff = target - theta;
      if (Math.abs(diff) < 0.3) {
        theta = target; draw(); updateReadout();
        cancelAnimationFrame(raf); raf = 0; return;
      }
      theta += diff * 0.18;
      draw(); updateReadout();
      raf = requestAnimationFrame(animate);
    }
    function animateTo(v: number) {
      target = v;
      if (!raf) raf = requestAnimationFrame(animate);
    }

    slider.addEventListener('input', () => {
      const v = parseFloat(slider.value);
      target = v; theta = v;            // スライダーは即時追従
      if (raf) { cancelAnimationFrame(raf); raf = 0; }
      draw(); updateReadout();
    });
    mulBtn.addEventListener('click', () => {
      const next = (Math.round(target) + 90) % 360;
      slider.value = String(next);
      animateTo(next);                  // ×j はくるっと回す
    });
    resetBtn.addEventListener('click', () => {
      slider.value = '30'; theta = 30; target = 30;
      if (raf) { cancelAnimationFrame(raf); raf = 0; }
      draw(); updateReadout();
    });

    draw(); updateReadout();
  }

  // ---- 複素数を繰り返し掛ける（螺旋）widget ----
  function mountSpiralIteration(root: HTMLElement) {
    root.classList.add('tw');
    root.innerHTML = `
      <div class="tw-title">複素数を繰り返し掛ける</div>
      <div class="tw-stage"><canvas width="680" height="680"></canvas></div>
      <div class="tw-controls">
        <div class="tw-row">
          <label>r = |c|</label>
          <input type="range" class="r" min="0.5" max="1.5" step="0.01" value="0.88" />
        </div>
        <div class="tw-row">
          <label>θ&nbsp;&nbsp;</label>
          <input type="range" class="t" min="2" max="90" step="1" value="24" />
        </div>
        <div class="tw-readout">
          c = <b class="rv">0.88</b> · e<sup>j·<b class="tv">24</b>°</sup>　→　zₙ = cⁿ·z₀
          <br /><span class="state"></span>
        </div>
        <div class="tw-btns">
          <button class="tw-btn p1">円 (r=1)</button>
          <button class="tw-btn p2">内巻き (r&lt;1)</button>
          <button class="tw-btn p3">外巻き (r&gt;1)</button>
        </div>
      </div>`;

    const canvas = root.querySelector('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const rIn = root.querySelector('input.r') as HTMLInputElement;
    const tIn = root.querySelector('input.t') as HTMLInputElement;
    const rv = root.querySelector('.rv') as HTMLElement;
    const tv = root.querySelector('.tv') as HTMLElement;
    const stateEl = root.querySelector('.state') as HTMLElement;

    const W = canvas.width, H = canvas.height;
    const cx = W / 2, cy = H / 2;
    const R0 = W * 0.40;               // z₀ の初期半径(px)

    const css = (v: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(v).trim();

    function draw() {
      const r = parseFloat(rIn.value);
      const thDeg = parseFloat(tIn.value);
      const th = thDeg * Math.PI / 180;
      rv.textContent = r.toFixed(2);
      tv.textContent = String(Math.round(thDeg));

      const accent = css('--accent') || '#3c7876';
      const border = css('--border') || '#e3dbd0';
      const faint = css('--text-faint') || '#aaa49b';
      ctx.clearRect(0, 0, W, H);

      // 軸
      ctx.strokeStyle = border; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(20, cy); ctx.lineTo(W - 20, cy);
      ctx.moveTo(cx, 20); ctx.lineTo(cx, H - 20); ctx.stroke();
      // z₀ の円（基準）
      ctx.strokeStyle = faint; ctx.lineWidth = 1; ctx.globalAlpha = 0.5;
      ctx.beginPath(); ctx.arc(cx, cy, R0, 0, Math.PI * 2); ctx.stroke();
      ctx.globalAlpha = 1;

      // 点列 zₙ = cⁿ·z₀  （半径 R0·rⁿ、角度 nθ）
      const pts: [number, number][] = [];
      let rad = R0;
      const maxR = W * 0.49, minR = 0.6;
      for (let n = 0; n <= 400; n++) {
        const ang = n * th;
        pts.push([cx + rad * Math.cos(ang), cy - rad * Math.sin(ang)]);
        rad *= r;
        if (r < 1 && rad < minR) break;
        if (r > 1 && rad > maxR) break;
        if (Math.abs(r - 1) < 1e-6 && n > Math.ceil(360 / thDeg) * 2) break;
      }

      // 螺旋の線
      ctx.strokeStyle = accent; ctx.lineWidth = 2.5; ctx.globalAlpha = 0.55;
      ctx.beginPath();
      pts.forEach(([x, y], i) => i ? ctx.lineTo(x, y) : ctx.moveTo(x, y));
      ctx.stroke(); ctx.globalAlpha = 1;

      // 各ステップの点
      ctx.fillStyle = accent;
      for (const [x, y] of pts) {
        ctx.beginPath(); ctx.arc(x, y, 3.5, 0, Math.PI * 2); ctx.fill();
      }
      // z₀ を強調
      const [x0, y0] = pts[0];
      ctx.fillStyle = accent;
      ctx.beginPath(); ctx.arc(x0, y0, 8, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#fff';
      ctx.beginPath(); ctx.arc(x0, y0, 3, 0, Math.PI * 2); ctx.fill();
      // 中心
      ctx.fillStyle = faint;
      ctx.beginPath(); ctx.arc(cx, cy, 3, 0, Math.PI * 2); ctx.fill();

      stateEl.textContent =
        r < 0.999 ? '内巻き — 中心へ吸い込まれる対数螺旋' :
        r > 1.001 ? '外巻き — 外へ広がる対数螺旋' :
                    '円 — 半径が変わらず回り続ける';
    }

    rIn.addEventListener('input', draw);
    tIn.addEventListener('input', draw);
    (root.querySelector('.p1') as HTMLElement).addEventListener('click', () => {
      rIn.value = '1.00'; tIn.value = '24'; draw();
    });
    (root.querySelector('.p2') as HTMLElement).addEventListener('click', () => {
      rIn.value = '0.88'; tIn.value = '24'; draw();
    });
    (root.querySelector('.p3') as HTMLElement).addEventListener('click', () => {
      rIn.value = '1.10'; tIn.value = '18'; draw();
    });

    draw();
  }

  // ---- 逆回りの2つの円 → 実振動（負周波数）widget ----
  function mountCounterRotation(root: HTMLElement) {
    root.classList.add('tw');
    root.innerHTML = `
      <div class="tw-title">逆回りの円が実振動になる</div>
      <div class="tw-stage"><canvas width="680" height="520"></canvas></div>
      <div class="tw-controls">
        <div class="tw-readout">
          ½e<sup>jθ</sup> + ½e<sup>−jθ</sup> = cos θ　<span class="deg"></span>
          <br /><span class="state" style="color:var(--text-muted);font-size:0.78rem;">
          反時計回りの円と時計回りの円。縦の動きは打ち消し合い、横だけが残る。</span>
        </div>
        <div class="tw-btns">
          <button class="tw-btn pause">一時停止</button>
        </div>
      </div>`;

    const canvas = root.querySelector('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const degEl = root.querySelector('.deg') as HTMLElement;
    const pauseBtn = root.querySelector('.pause') as HTMLElement;

    const W = canvas.width, H = canvas.height;
    const cx = W * 0.34, cy = H * 0.5;   // 複素平面の中心（左寄せ）
    const R = H * 0.32;                   // 単位円の半径(px)
    const half = R / 2;                   // 各フェーザの長さ ½
    const waveX = W * 0.62;               // 波形の開始x
    const css = (v: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(v).trim();

    let theta = 0;
    let running = true;
    const trail: number[] = [];           // cosθ の履歴

    function draw() {
      const accent = css('--accent') || '#3c7876';
      const border = css('--border') || '#e3dbd0';
      const faint = css('--text-faint') || '#aaa49b';
      ctx.clearRect(0, 0, W, H);

      // 軸
      ctx.strokeStyle = border; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(cx - R - 30, cy); ctx.lineTo(W - 20, cy);
      ctx.moveTo(cx, cy - R - 30); ctx.lineTo(cx, cy + R + 30); ctx.stroke();

      // 単位円
      ctx.strokeStyle = faint; ctx.lineWidth = 1; ctx.globalAlpha = 0.5;
      ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI * 2); ctx.stroke();
      ctx.globalAlpha = 1;

      const c = Math.cos(theta), s = Math.sin(theta);
      // 反時計回り ½e^{jθ}
      const ax = cx + half * c, ay = cy - half * s;
      // 時計回り ½e^{-jθ}
      const bx = cx + half * c, by = cy + half * s;
      // 和（実軸上）
      const sx = cx + R * c, sy = cy;

      // 平行四辺形（和の作図）
      ctx.strokeStyle = faint; ctx.lineWidth = 1.5; ctx.setLineDash([4, 4]);
      ctx.beginPath();
      ctx.moveTo(ax, ay); ctx.lineTo(sx, sy); ctx.lineTo(bx, by);
      ctx.stroke(); ctx.setLineDash([]);

      // 2本のフェーザ
      const arrow = (x: number, y: number, col: string) => {
        ctx.strokeStyle = col; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(x, y); ctx.stroke();
        ctx.fillStyle = col;
        ctx.beginPath(); ctx.arc(x, y, 5, 0, Math.PI * 2); ctx.fill();
      };
      arrow(ax, ay, accent);
      arrow(bx, by, faint);

      // 和ベクトル（実軸上）
      ctx.strokeStyle = accent; ctx.lineWidth = 4;
      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(sx, sy); ctx.stroke();
      ctx.fillStyle = accent;
      ctx.beginPath(); ctx.arc(sx, sy, 7, 0, Math.PI * 2); ctx.fill();

      // 右側に cosθ の波形（時間を右へ）
      trail.unshift(c);
      if (trail.length > 220) trail.pop();
      // 和の点から波形開始へ結ぶガイド
      ctx.strokeStyle = accent; ctx.lineWidth = 1; ctx.globalAlpha = 0.3; ctx.setLineDash([3, 3]);
      ctx.beginPath(); ctx.moveTo(sx, sy); ctx.lineTo(waveX, cy - R * c); ctx.stroke();
      ctx.setLineDash([]); ctx.globalAlpha = 1;
      ctx.strokeStyle = accent; ctx.lineWidth = 2.5;
      ctx.beginPath();
      for (let i = 0; i < trail.length; i++) {
        const x = waveX + i * 0.5;
        const y = cy - R * trail[i];
        i ? ctx.lineTo(x, y) : ctx.moveTo(x, y);
      }
      ctx.stroke();

      degEl.textContent = `(θ = ${Math.round((theta * 180 / Math.PI) % 360)}°)`;
    }

    function tick() {
      if (!running) return;
      theta += 0.03;
      draw();
      requestAnimationFrame(tick);
    }
    pauseBtn.addEventListener('click', () => {
      running = !running;
      pauseBtn.textContent = running ? '一時停止' : '再生';
      if (running) tick();
    });
    draw(); tick();
  }

  // ---- バグ vs 修正：6回回転の比較ビジュアル ----
  function mountCrystalBugCompare(root: HTMLElement) {
    root.classList.add('tw', 'tw-wide');
    root.innerHTML = `
      <div class="tw-title">同じ6回回転、符号ひとつの違い</div>
      <div class="tw-stage"><canvas width="760" height="430"></canvas></div>
      <div class="tw-readout" style="font-size:0.78rem;color:var(--text-muted);line-height:1.6;">
        左は 240°回転の行列の右下を <b>+0.5</b> にしてしまった当時のコード。行列式が 0.5 になり、
        そのかけら（橙）だけ面積が半分に縮んで歪み、六角形が閉じない。<br />
        右は右下を <b>−0.5</b> に直した正しい回転。6枚がきれいに揃う。
      </div>`;

    const canvas = root.querySelector('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const W = canvas.width, H = canvas.height;
    const css = (v: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(v).trim();

    // 向きが分かるよう非対称なモチーフ（半径1付近の小さな三角）
    const motif: [number, number][] = [[1.04, -0.05], [0.74, 0.03], [0.92, 0.27]];
    const correct = [
      [1, 0, 0, 1], [0.5, -0.866, 0.866, 0.5], [-0.5, -0.866, 0.866, -0.5],
      [-1, 0, 0, -1], [-0.5, 0.866, -0.866, -0.5], [0.5, 0.866, -0.866, 0.5],
    ];
    const buggy = correct.map((o, i) =>
      i === 4 ? [-0.5, 0.866, -0.866, 0.5] : o);   // 240° の右下符号だけ違う

    function panel(centerX: number, ops: number[][], label: string) {
      const accent = css('--accent') || '#3c7876';
      const faint = css('--text-faint') || '#aaa49b';
      const amber = '#8c6d4f';
      const text = css('--text-muted') || '#6b6557';
      const cy = H * 0.54, scale = 92;

      // 単位円・中心
      ctx.strokeStyle = faint; ctx.lineWidth = 1; ctx.globalAlpha = 0.45;
      ctx.beginPath(); ctx.arc(centerX, cy, scale, 0, Math.PI * 2); ctx.stroke();
      ctx.globalAlpha = 1;
      ctx.fillStyle = faint;
      ctx.beginPath(); ctx.arc(centerX, cy, 3, 0, Math.PI * 2); ctx.fill();

      ops.forEach((op, i) => {
        const [a, b, c, d] = op;
        const isHot = i === 4;                       // 240° のかけら
        ctx.beginPath();
        motif.forEach(([x, y], j) => {
          const X = a * x + b * y, Y = c * x + d * y;
          const px = centerX + scale * X, py = cy - scale * Y;
          j ? ctx.lineTo(px, py) : ctx.moveTo(px, py);
        });
        ctx.closePath();
        ctx.fillStyle = isHot ? 'rgba(140,109,79,0.30)' : 'rgba(60,120,118,0.16)';
        ctx.fill();
        ctx.strokeStyle = isHot ? amber : accent; ctx.lineWidth = 2; ctx.stroke();
      });

      ctx.fillStyle = text; ctx.font = '600 19px "JetBrains Mono", monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText(label, centerX, 14);
    }

    ctx.clearRect(0, 0, W, H);
    panel(W * 0.27, buggy, 'バグ：det 0.5');
    panel(W * 0.73, correct, '修正後：det 1');
  }

  // ---- バグ vs 修正：負の周波数の比較ビジュアル ----
  function mountFourierBugCompare(root: HTMLElement) {
    root.classList.add('tw', 'tw-wide');
    root.innerHTML = `
      <div class="tw-title">負の周波数を落とすと線が閉じない</div>
      <div class="tw-stage"><canvas width="760" height="430"></canvas></div>
      <div class="tw-readout" style="font-size:0.78rem;color:var(--text-muted);line-height:1.6;">
        同じ四角形を円の重ね合わせで再現する。左は <b>freq = k</b>（バグ）。後半の円が逆回りにならず
        猛烈に正回転して、点と点の間で線が暴れる。右は <b>k &gt; N/2 を k−N に</b>直したもの。静かに四角を描く。
      </div>
      <div class="tw-btns"><button class="tw-btn pause">一時停止</button></div>`;

    const canvas = root.querySelector('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const pauseBtn = root.querySelector('.pause') as HTMLElement;
    const W = canvas.width, H = canvas.height;
    const css = (v: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(v).trim();

    // 四角形を N 点でサンプリング（実部=x, 虚部=y）
    const N = 64, S = 1;
    const pts: [number, number][] = [];
    for (let i = 0; i < N; i++) {
      const f = (i / N) * 4, side = Math.floor(f), u = f - side;
      let x = 0, y = 0;
      if (side === 0) { x = -S + 2 * S * u; y = -S; }
      else if (side === 1) { x = S; y = -S + 2 * S * u; }
      else if (side === 2) { x = S - 2 * S * u; y = S; }
      else { x = -S; y = S - 2 * S * u; }
      pts.push([x, y]);
    }

    // DFT 係数 X_k = (1/N) Σ z_n e^{-j2πkn/N}
    const Xre: number[] = [], Xim: number[] = [];
    for (let k = 0; k < N; k++) {
      let re = 0, im = 0;
      for (let n = 0; n < N; n++) {
        const a = (2 * Math.PI * k * n) / N, ca = Math.cos(a), sa = Math.sin(a);
        re += pts[n][0] * ca + pts[n][1] * sa;
        im += pts[n][1] * ca - pts[n][0] * sa;
      }
      Xre.push(re / N); Xim.push(im / N);
    }
    const freqBuggy = (k: number) => k;
    const freqCorrect = (k: number) => (k <= N / 2 ? k : k - N);

    // 連続パラメータ t∈[0,2π) で再構成して経路を先に作る
    const M = 1600;
    function buildPath(freq: (k: number) => number): [number, number][] {
      const path: [number, number][] = [];
      for (let m = 0; m < M; m++) {
        const t = (2 * Math.PI * m) / M;
        let xr = 0, xi = 0;
        for (let k = 0; k < N; k++) {
          const b = freq(k) * t, cb = Math.cos(b), sb = Math.sin(b);
          xr += Xre[k] * cb - Xim[k] * sb;
          xi += Xre[k] * sb + Xim[k] * cb;
        }
        path.push([xr, xi]);
      }
      return path;
    }
    const pathBug = buildPath(freqBuggy);
    const pathFix = buildPath(freqCorrect);

    const cy = H * 0.54, scale = 78;
    function panel(centerX: number, path: [number, number][], head: number, label: string, hot: boolean) {
      const accent = css('--accent') || '#3c7876';
      const faint = css('--text-faint') || '#aaa49b';
      const amber = '#8c6d4f';
      const text = css('--text-muted') || '#6b6557';

      // サンプル点（元の四角形の頂点列）
      ctx.fillStyle = faint; ctx.globalAlpha = 0.5;
      for (const [x, y] of pts) {
        ctx.beginPath();
        ctx.arc(centerX + scale * x, cy - scale * y, 1.6, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;

      // 経路全体（薄く）
      ctx.strokeStyle = hot ? amber : accent; ctx.globalAlpha = 0.22; ctx.lineWidth = 1;
      ctx.beginPath();
      path.forEach(([x, y], i) =>
        i ? ctx.lineTo(centerX + scale * x, cy - scale * y) : ctx.moveTo(centerX + scale * x, cy - scale * y));
      ctx.closePath(); ctx.stroke(); ctx.globalAlpha = 1;

      // 明るい尾（直近 160 点）
      ctx.strokeStyle = hot ? amber : accent; ctx.lineWidth = 2;
      ctx.beginPath();
      const tail = 160;
      for (let j = 0; j < tail; j++) {
        const idx = (head - tail + j + M) % M;
        const [x, y] = path[idx];
        j ? ctx.lineTo(centerX + scale * x, cy - scale * y) : ctx.moveTo(centerX + scale * x, cy - scale * y);
      }
      ctx.stroke();

      // ペン先
      const [hx, hy] = path[head % M];
      ctx.fillStyle = hot ? amber : accent;
      ctx.beginPath(); ctx.arc(centerX + scale * hx, cy - scale * hy, 4, 0, Math.PI * 2); ctx.fill();

      ctx.fillStyle = text; ctx.font = '600 17px "JetBrains Mono", monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText(label, centerX, 14);
    }

    let head = 0, running = true;
    function frame() {
      ctx.clearRect(0, 0, W, H);
      panel(W * 0.27, pathBug, head, 'バグ：freq = k', true);
      panel(W * 0.73, pathFix, head, '修正後：k−N も使う', false);
      head = (head + 6) % M;
      if (running) requestAnimationFrame(frame);
    }
    pauseBtn.addEventListener('click', () => {
      running = !running;
      pauseBtn.textContent = running ? '一時停止' : '再生';
      if (running) frame();
    });
    frame();
  }

  // ---- 標本化とエイリアシング（見かけの逆回り）widget ----
  function mountAliasing(root: HTMLElement) {
    root.classList.add('tw');
    root.innerHTML = `
      <div class="tw-title">サンプリングで逆回りに見える</div>
      <div class="tw-stage"><canvas width="640" height="640"></canvas></div>
      <div class="tw-controls">
        <div class="tw-row">
          <label>回転の速さ</label>
          <input type="range" class="f" min="0.1" max="1.2" step="0.02" value="0.45" />
        </div>
        <div class="tw-row">
          <label>標本数 / 回転</label>
          <input type="range" class="s" min="0.8" max="12" step="0.1" value="8" />
        </div>
        <div class="tw-readout">
          <b class="sv">8.0</b> 点で1回転を刻む　・　ナイキスト = 2 点/回転
          <br /><span class="state"></span>
        </div>
        <div class="tw-btns">
          <button class="tw-btn pause">一時停止</button>
        </div>
      </div>`;

    const canvas = root.querySelector('canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const fIn = root.querySelector('input.f') as HTMLInputElement;
    const sIn = root.querySelector('input.s') as HTMLInputElement;
    const sv = root.querySelector('.sv') as HTMLElement;
    const stateEl = root.querySelector('.state') as HTMLElement;
    const pauseBtn = root.querySelector('.pause') as HTMLElement;

    const W = canvas.width, H = canvas.height;
    const cx = W / 2, cy = H / 2, R = W * 0.38;
    const css = (v: string) =>
      getComputedStyle(document.documentElement).getPropertyValue(v).trim();

    let trueAng = 0;                // 真の位相 [rad]
    let lastT = performance.now();
    let sampleAcc = 0;              // 前回標本からの経過 [秒]
    let samples: { ang: number; age: number }[] = [];   // 直近の標本（新しい順）
    let running = true, raf = 0;

    const wrapPi = (a: number) =>
      ((a + Math.PI) % (2 * Math.PI) + 2 * Math.PI) % (2 * Math.PI) - Math.PI;

    function draw() {
      const S = parseFloat(sIn.value);
      const accent = css('--accent') || '#3c7876';
      const border = css('--border') || '#e3dbd0';
      const faint = css('--text-faint') || '#aaa49b';
      const amber = '#8c6d4f';
      ctx.clearRect(0, 0, W, H);

      // 軸・単位円
      ctx.strokeStyle = border; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(20, cy); ctx.lineTo(W - 20, cy);
      ctx.moveTo(cx, 20); ctx.lineTo(cx, H - 20); ctx.stroke();
      ctx.strokeStyle = faint; ctx.lineWidth = 1.5; ctx.globalAlpha = 0.5;
      ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI * 2); ctx.stroke();
      ctx.globalAlpha = 1;

      // 真の連続位置（薄く・速く反時計回り）
      const tx = cx + R * Math.cos(trueAng), ty = cy - R * Math.sin(trueAng);
      ctx.strokeStyle = faint; ctx.lineWidth = 2; ctx.globalAlpha = 0.55;
      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(tx, ty); ctx.stroke();
      ctx.globalAlpha = 1;
      ctx.fillStyle = faint;
      ctx.beginPath(); ctx.arc(tx, ty, 5, 0, Math.PI * 2); ctx.fill();

      // 見かけのステップ（最新→1つ前への短い方の弧）の向きで色分け
      const appStep = wrapPi(2 * Math.PI / S);     // 1標本あたりの見かけの進み [rad]
      const appCW = appStep < -0.03;               // 時計回りに見える＝見かけの負の周波数
      const hot = appCW ? amber : accent;

      // 標本点（古いものほど薄く）
      samples.forEach((s, i) => {
        const a = Math.max(0, 1 - i / 10) * Math.max(0, 1 - s.age * 0.5);
        if (a <= 0) return;
        const px = cx + R * Math.cos(s.ang), py = cy - R * Math.sin(s.ang);
        ctx.globalAlpha = a * 0.9;
        ctx.fillStyle = hot;
        ctx.beginPath(); ctx.arc(px, py, 4, 0, Math.PI * 2); ctx.fill();
      });
      ctx.globalAlpha = 1;

      // 見かけのフェーザ（最新の標本へ）
      if (samples[0]) {
        const px = cx + R * Math.cos(samples[0].ang), py = cy - R * Math.sin(samples[0].ang);
        ctx.strokeStyle = hot; ctx.lineWidth = 4;
        ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(px, py); ctx.stroke();
        ctx.fillStyle = hot;
        ctx.beginPath(); ctx.arc(px, py, 8, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#fff';
        ctx.beginPath(); ctx.arc(px, py, 3.2, 0, Math.PI * 2); ctx.fill();
      }

      // 見かけの進み方向を示す弧矢印（中心付近）
      if (Math.abs(appStep) > 0.03 && samples[1]) {
        const r2 = R * 0.2;
        ctx.strokeStyle = hot; ctx.lineWidth = 3; ctx.globalAlpha = 0.7;
        ctx.beginPath();
        ctx.arc(cx, cy, r2, -samples[1].ang, -samples[1].ang - appStep, appStep < 0);
        ctx.stroke(); ctx.globalAlpha = 1;
      }

      // 読み出し
      const appDeg = appStep * 180 / Math.PI;
      const dir = Math.abs(appDeg) < 3 ? '止まって見える'
        : appDeg > 0 ? '反時計回り（本当の向き）'
        : '時計回り＝見かけの負の周波数';
      const ny = S >= 2
        ? 'ナイキスト以上：本当の向きが見える'
        : 'ナイキスト未満：折り返して逆に見える';
      stateEl.innerHTML =
        `本当は<b style="color:${faint}">反時計回り</b>、見かけは<b style="color:${hot}">${dir}</b><br>${ny}`;
      sv.textContent = S.toFixed(1);
    }

    function tick(now: number) {
      if (!running) return;
      const dt = Math.min((now - lastT) / 1000, 0.05);
      lastT = now;
      const F = parseFloat(fIn.value);                 // 回転の速さ [回転/秒]
      const S = parseFloat(sIn.value);
      trueAng += 2 * Math.PI * F * dt;                 // 反時計回り
      const Ts = 1 / (F * S);                          // 標本間隔 [秒]
      sampleAcc += dt;
      while (sampleAcc >= Ts) {
        sampleAcc -= Ts;
        samples.unshift({ ang: trueAng, age: 0 });
        if (samples.length > 12) samples.pop();
      }
      for (const s of samples) s.age += dt;
      draw();
      raf = requestAnimationFrame(tick);
    }

    const reset = () => { samples = []; sampleAcc = 0; draw(); };
    fIn.addEventListener('input', reset);
    sIn.addEventListener('input', reset);
    pauseBtn.addEventListener('click', () => {
      running = !running;
      pauseBtn.textContent = running ? '一時停止' : '再生';
      if (running) { lastT = performance.now(); raf = requestAnimationFrame(tick); }
    });
    draw();
    raf = requestAnimationFrame(tick);
  }

  // ---- マウンタ ----
  function mountAll() {
    document.querySelectorAll<HTMLElement>('[data-widget]').forEach((el) => {
      if (el.dataset.mounted) return;
      el.dataset.mounted = '1';
      switch (el.dataset.widget) {
        case 'complex-rotation': mountComplexRotation(el); break;
        case 'spiral-iteration': mountSpiralIteration(el); break;
        case 'counter-rotation': mountCounterRotation(el); break;
        case 'crystal-bug-compare': mountCrystalBugCompare(el); break;
        case 'fourier-bug-compare': mountFourierBugCompare(el); break;
        case 'aliasing': mountAliasing(el); break;
      }
    });
  }
  if (document.readyState === 'loading')
    document.addEventListener('DOMContentLoaded', mountAll);
  else mountAll();
</script>
