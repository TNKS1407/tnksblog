---
const today = new Date();
---

<footer>
  <div class="inner">
    <span>© {today.getFullYear()} tnksblog <span class="count" id="hit-counter" hidden>· 👁 <span id="hit-n">—</span></span></span>
    <div class="links">
      <a href="https://tnks1407.com" target="_blank">Works</a>
      <a href="https://github.com/TNKS1407" target="_blank">GitHub</a>
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
  <div class="credit">curated by ランキン</div>
</footer>

<script is:inline>
  (function(){
    var path = location.pathname.replace(/\/index\.html$/,'').replace(/\/$/,'') || '/';
    var key = path === '/' ? 'home' : path.replace(/^\//,'').replace(/\//g,'-');
    var hit = 'hit_' + key;
    var doHit = !sessionStorage.getItem(hit);
    if (doHit) sessionStorage.setItem(hit, '1');
    fetch('/api/hit?p=' + encodeURIComponent(key) + (doHit ? '&hit=1' : ''))
      .then(function(r){ return r.json(); })
      .then(function(d){ if (d && d.count != null){ document.getElementById('hit-n').textContent = d.count.toLocaleString(); document.getElementById('hit-counter').hidden=false; } })
      .catch(function(){});
  })();
</script>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.75rem 1.5rem 1.25rem;
    margin-top: 4rem;
    background: var(--surface);
  }
  .inner {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.75rem;
    font-size: 0.82rem; color: var(--text-muted);
  }
  .links { display: flex; gap: 1rem; }
  .links a { color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
  .links a:hover { color: var(--accent); opacity: 1; }
  .credit {
    max-width: 900px; margin: 0.5rem auto 0;
    font-size: 0.7rem; color: var(--text-faint);
    font-family: 'JetBrains Mono', monospace;
  }
</style>
