---
const today = new Date();
---

<footer>
  <div class="inner">
    <span>© {today.getFullYear()} tnksblog <span class="count" id="hit-counter" hidden>· 👁 <span id="hit-n">—</span></span></span>
    <div class="links">
      <a href="https://tnks1407.com" target="_blank">Works</a>
      <a href="https://github.com/TNKS1407" target="_blank">GitHub</a>
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
  <div class="credit">curated by ランキン</div>
</footer>

<script is:inline>
  // 母艦(feedback.tnks1407.com)のビューカウンターを使う。tnkblogは実験相なので
  // tnks1407への参照はOK。キーは "tnkblog-<page>"。tnks1407側の集計とは混ざらない。
  (function(){
    var API = 'https://feedback.tnks1407.com';
    var path = location.pathname.replace(/\/index\.html$/,'').replace(/\/$/,'') || '/';
    var sub = path === '/' ? 'home' : path.replace(/^\//,'').replace(/\//g,'-').toLowerCase().replace(/[^a-z0-9-]/g,'');
    var key = 'tnkblog-' + sub;
    var flag = 'hit_' + key;
    var el = document.getElementById('hit-counter');
    function show(n){ if (n != null){ document.getElementById('hit-n').textContent = Number(n).toLocaleString(); el.hidden = false; } }
    function read(){ fetch(API + '/views').then(function(r){ return r.json(); }).then(function(v){ show((v && v[key]) || 0); }).catch(function(){}); }
    if (!sessionStorage.getItem(flag)) {
      sessionStorage.setItem(flag, '1');
      fetch(API + '/view?key=' + encodeURIComponent(key), { method: 'POST' })
        .then(function(r){ return r.json(); })
        .then(function(d){ show(d.count); })
        .catch(read);
    } else { read(); }
  })();
</script>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.75rem 1.5rem 1.25rem;
    margin-top: 4rem;
    background: var(--surface);
  }
  .inner {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.75rem;
    font-size: 0.82rem; color: var(--text-muted);
  }
  .links { display: flex; gap: 1rem; }
  .links a { color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
  .links a:hover { color: var(--accent); opacity: 1; }
  .credit {
    max-width: 900px; margin: 0.5rem auto 0;
    font-size: 0.7rem; color: var(--text-faint);
    font-family: 'JetBrains Mono', monospace;
  }
</style>
