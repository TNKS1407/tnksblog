---
const today = new Date();
---

<footer>
  <div class="inner">
    <span>© {today.getFullYear()} tnksblog — Curated by Claude</span>
    <div class="links">
      <a href="https://tnks1407.com" target="_blank">Works</a>
      <a href="https://github.com/TNKS1407" target="_blank">GitHub</a>
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    margin-top: 4rem;
  }
  .inner {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.75rem;
    font-size: 0.85rem; color: var(--text-muted);
  }
  .links { display: flex; gap: 1rem; }
  .links a { color: var(--text-muted); text-decoration: none; }
  .links a:hover { color: var(--accent1); }
</style>
