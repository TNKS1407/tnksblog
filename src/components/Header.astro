---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="logo">{SITE_TITLE}</a>
    <div class="links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">記事一覧</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <a href="https://tnks1407.com" target="_blank" class="ext-link">Works ↗</a>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(245,242,236,0.90);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid #e3dbd0;
    padding: 0 1.5rem;
  }
  nav {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 52px;
  }
  .logo {
    font-size: 1rem; font-weight: 700;
    color: #1d1b17;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: .02em;
  }
  .logo:hover { color: #3c7876; opacity: 1; }
  .links { display: flex; gap: 0.15rem; align-items: center; }
  .ext-link {
    padding: 0.3rem 0.65rem;
    color: #7d7568; font-size: 0.82rem; font-weight: 500;
    text-decoration: none; border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .ext-link:hover { color: #3c7876; background: rgba(60,120,118,0.09); opacity: 1; }
  @media (max-width: 480px) { .ext-link { display: none; } }
</style>
